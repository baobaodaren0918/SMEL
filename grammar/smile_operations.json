    "ADD_PARTITION_KEY": {
      "category": "add",
      "specific": "ADD_PARTITION_KEY",
      "generalized": "ADD PARTITION KEY",
      "doc": "Add a Cassandra partition key",
      "syntax_specific": "ADD_PARTITION_KEY <entity.field|(f1,f2)> [AS <dataType>] [TO <entity>]",
      "syntax_generalized": "ADD PARTITION KEY <entity.field|(f1,f2)> [AS <dataType>] [TO <entity>]",
      "snippet_specific": "ADD_PARTITION_KEY ${1:entity}.${2:field}$0",
