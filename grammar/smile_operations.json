    "ADD_CONSTRAINT": {
      "category": "add",
      "specific": "ADD_CONSTRAINT",
      "generalized": "ADD CONSTRAINT",
      "doc": "Add a logical reference, CHECK predicate, or EXISTENCE constraint. Covers constraint kinds NOT addressed by the narrow operators (ADD_PRIMARY_KEY / ADD_UNIQUE_KEY / ADD_FOREIGN_KEY / ADD_PARTITION_KEY / ADD_CLUSTERING_KEY / ADD_LABEL). Enforced foreign keys go through ADD_FOREIGN_KEY (also the only path that supports composite keys).",
      "syntax_specific": "ADD_CONSTRAINT <entity.field> AS (REFERENCE LOGICAL TO <target>(<col>) [WITH CARDINALITY <type>] | CHECK <expr> | EXISTENCE)",
      "syntax_generalized": "ADD CONSTRAINT <entity.field> AS (REFERENCE LOGICAL TO <target>(<col>) [WITH CARDINALITY <type>] | CHECK <expr> | EXISTENCE)",
      "snippet_specific": "ADD_CONSTRAINT ${1:entity}.${2:field} AS ${3|REFERENCE LOGICAL TO target(_id),CHECK price > 0,EXISTENCE|}$0",
      "snippet_generalized": "ADD CONSTRAINT ${1:entity}.${2:field} AS ${3|REFERENCE LOGICAL TO target(_id),CHECK price > 0,EXISTENCE|}$0",
      "template_specific": "ADD_CONSTRAINT {target} AS {body}",
      "template_generalized": "ADD CONSTRAINT {target} AS {body}",
      "clauses": [
        {"name": "AS REFERENCE LOGICAL TO ...", "snippet": "AS REFERENCE LOGICAL TO ${1:target_entity}(${2:target_field}) WITH CARDINALITY ${3|ONE_TO_ONE,ZERO_TO_ONE,ONE_TO_MANY,ZERO_TO_MANY|}", "optional": false, "doc": "Logical (non-enforced) cross-entity reference. Useful for Mongo cross-collection ObjectId refs, Cassandra denormalised columns, and self-references. Enforced FKs go through ADD_FOREIGN_KEY."},
        {"name": "AS CHECK <expr>", "snippet": "AS CHECK ${1:price} ${2|>,>=,<,<=,==,!=|} ${3:0}", "optional": false, "doc": "Structured CHECK predicate. Atoms: ``f op v``, ``f IN (v1, v2)``, ``f BETWEEN low AND high``, ``f MATCHES \"pattern\"``, ``f IS [NOT] NULL``. Compose with AND / OR / NOT / parens. RAW \"...\" is the escape hatch for unsupported predicates."},
        {"name": "AS EXISTENCE", "snippet": "AS EXISTENCE", "optional": false, "doc": "NOT NULL applied post-hoc to an existing property. Native on PG / Mongo / Neo4j; key columns only on Cassandra."}
      ]
    },

    "ADD_EMBEDDED": {
      "category": "add",
      "specific": "ADD_EMBEDDED",
      "generalized": "ADD EMBEDDED",
      "doc": "Add an embedded object relationship (MongoDB style)",
      "syntax_specific": "ADD_EMBEDDED <name> TO <entity> [WITH CARDINALITY <type>] [WITH STRUCTURE (f1, f2, ...)]",
      "syntax_generalized": "ADD EMBEDDED <name> TO <entity> [WITH CARDINALITY <type>] [WITH STRUCTURE (f1, f2, ...)]",
      "snippet_specific": "ADD_EMBEDDED ${1:embed_name} TO ${2:entity} WITH CARDINALITY ${3|ONE_TO_ONE,ZERO_TO_ONE,ONE_TO_MANY,ZERO_TO_MANY|}$0",
      "snippet_generalized": "ADD EMBEDDED ${1:embed_name} TO ${2:entity} WITH CARDINALITY ${3|ONE_TO_ONE,ZERO_TO_ONE,ONE_TO_MANY,ZERO_TO_MANY|}$0",
      "template_specific": "ADD_EMBEDDED {name} TO {entity}{cardinality_clause}{structure_clause}",
      "template_generalized": "ADD EMBEDDED {name} TO {entity}{cardinality_clause}{structure_clause}",
      "when_target": ["document"],
      "clauses": [
        {"name": "WITH CARDINALITY", "values_ref": "cardinalityType", "optional": true},
        {"name": "WITH STRUCTURE", "snippet": "WITH STRUCTURE (${1:field1}, ${2:field2})", "optional": true}
      ]
    },

    "ADD_ENTITY": {
      "category": "add",
      "specific": "ADD_ENTITY",
      "generalized": "ADD ENTITY",
      "doc": "Add a new entity (table/document/node) or edge (graph relationship type)",
      "syntax_specific": "ADD_ENTITY <name> [FROM <src> TO <tgt>] [WITH CARDINALITY <type>] [WITH PROPERTIES (n1 T1, n2 T2, ...)] [WITH KEY <name>]",
      "syntax_generalized": "ADD ENTITY <name> [FROM <src> TO <tgt>] [WITH CARDINALITY <type>] [WITH PROPERTIES (n1 T1, n2 T2, ...)] [WITH KEY <name>]",
      "snippet_specific": "ADD_ENTITY ${1:EntityName} WITH PROPERTIES (${2:id} ${3|String,Integer,UUID|}, ${4:name} ${5|String,Text|})$0",
      "snippet_generalized": "ADD ENTITY ${1:EntityName} WITH PROPERTIES (${2:id} ${3|String,Integer,UUID|}, ${4:name} ${5|String,Text|})$0",
      "template_specific": "ADD_ENTITY {name}{edge_endpoints}{cardinality_clause}{properties_clause}{key_clause}",
      "template_generalized": "ADD ENTITY {name}{edge_endpoints}{cardinality_clause}{properties_clause}{key_clause}",
      "clauses": [
        {"name": "FROM ... TO ...", "snippet": "FROM ${1:source_entity} TO ${2:target_entity}", "optional": true, "doc": "Edge endpoints (graph database only)"},
        {"name": "WITH CARDINALITY", "values_ref": "cardinalityType", "optional": true},
        {"name": "WITH PROPERTIES", "snippet": "WITH PROPERTIES (${1:name} ${2|String,Integer|})", "optional": true},
        {"name": "WITH KEY", "snippet": "WITH KEY ${1:key_name}", "optional": true}
      ]
    },

