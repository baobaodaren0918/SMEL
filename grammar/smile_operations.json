      "syntax_generalized": "ADD UNIQUE KEY <entity.field|(f1,f2)> [AS <dataType>] [TO <entity>]",
      "snippet_specific": "ADD_UNIQUE_KEY ${1:entity}.${2:field}$0",
      "snippet_generalized": "ADD UNIQUE KEY ${1:entity}.${2:field}$0",
      "template_specific": "ADD_UNIQUE_KEY {key_columns}{as_clause}{to_clause}",
