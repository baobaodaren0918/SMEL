{
  "$comment": "Single source of truth for SMILE operations. Used by CodeMirror autocomplete (client-side). Each operation: 'specific' = .smile keyword (underscore form), 'generalized' = .smile_gen keyword (space form). 'template_specific'/'template_generalized' use Python str.format placeholders ({entity}, {field}, etc.). 'snippet' uses the LSP/textmate ${1:label} syntax for editor expansion. 'clauses' each may have: name, values (enum), snippet, optional, when (entity_kind filter), doc.",
  "version": "1.0",
  "header": {
    "migration": {
      "snippet": "MIGRATION ${1:migration_name}:${2:1.0}\nFROM ${3|RELATIONAL,DOCUMENT,GRAPH,COLUMNAR|} TO ${4|RELATIONAL,DOCUMENT,GRAPH,COLUMNAR|}\nUSING ${5:schema_name} VERSION ${6:1.0}\n\n$0",
      "template": "MIGRATION {name}:{version}\nFROM {source_type} TO {target_type}\nUSING {schema_name} VERSION {schema_version}"
    },
    "evolution": {
      "snippet": "EVOLUTION ${1:evolution_name}:${2:1.0}\nFROM ${3|RELATIONAL,DOCUMENT,GRAPH,COLUMNAR|} TO ${4|RELATIONAL,DOCUMENT,GRAPH,COLUMNAR|}\nUSING ${5:schema_name} VERSION ${6:1.0} TO ${7:2.0}\n\n$0",
      "template": "EVOLUTION {name}:{version}\nFROM {source_type} TO {target_type}\nUSING {schema_name} VERSION {schema_version_from} TO {schema_version_to}"
    }
  },
  "enums": {
    "databaseType": ["RELATIONAL", "DOCUMENT", "GRAPH", "COLUMNAR"],
    "cardinalityType": ["ONE_TO_ONE", "ONE_TO_MANY", "ZERO_TO_ONE", "ZERO_TO_MANY"],
    "constraintKeyType": ["PRIMARY KEY", "UNIQUE KEY", "PARTITION KEY", "CLUSTERING KEY", "NODE KEY", "DOCUMENT_ID"],
    "dataType": ["String", "Text", "Int", "Integer", "Long", "Double", "Float", "Decimal", "Boolean", "Date", "DateTime", "Timestamp", "UUID", "Binary"]
  },
  "operations": {
    "ADD_PROPERTY": {
      "category": "add",
      "specific": "ADD_PROPERTY",
      "generalized": "ADD PROPERTY",
      "doc": "Add a new property to an entity",
      "syntax_specific": "ADD_PROPERTY <name> [TO <entity>] [WITH TYPE <dataType>] [WITH DEFAULT <literal>] [NOT NULL]",
      "syntax_generalized": "ADD PROPERTY <name> [TO <entity>] [WITH TYPE <dataType>] [WITH DEFAULT <literal>] [NOT NULL]",
      "snippet_specific": "ADD_PROPERTY ${1:property_name} TO ${2:entity} WITH TYPE ${3|String,Text,Integer,Long,Double,Decimal,Boolean,Date,Timestamp,UUID|}$0",
      "snippet_generalized": "ADD PROPERTY ${1:property_name} TO ${2:entity} WITH TYPE ${3|String,Text,Integer,Long,Double,Decimal,Boolean,Date,Timestamp,UUID|}$0",
      "template_specific": "ADD_PROPERTY {name} TO {entity}{type_clause}{default_clause}{notnull_clause}",
      "template_generalized": "ADD PROPERTY {name} TO {entity}{type_clause}{default_clause}{notnull_clause}",
      "clauses": [
        {"name": "WITH TYPE", "values_ref": "dataType", "optional": true, "doc": "Property data type"},
        {"name": "WITH DEFAULT", "snippet": "WITH DEFAULT ${1:value}", "optional": true, "doc": "Default value literal"},
        {"name": "NOT NULL", "optional": true, "doc": "Disallow null values"}
      ]
    },

    "ADD_FOREIGN_KEY": {
      "category": "add",
      "specific": "ADD_FOREIGN_KEY",
      "generalized": "ADD FOREIGN KEY",
      "doc": "Add a foreign key constraint with REFERENCES (single-column or composite)",
      "syntax_specific": "ADD_FOREIGN_KEY <entity.field|(f1,f2,..) TO <entity>> REFERENCES <entity>(<field|f1,f2,..>) [WITH CARDINALITY <type>] [USING KEY <name>] [WHERE <cond>]",
      "syntax_generalized": "ADD FOREIGN KEY <entity.field|(f1,f2,..) TO <entity>> REFERENCES <entity>(<field|f1,f2,..>) [WITH CARDINALITY <type>] [USING KEY <name>] [WHERE <cond>]",
      "snippet_specific": "ADD_FOREIGN_KEY ${1:entity}.${2:field} REFERENCES ${3:target_entity}(${4:target_field})$0",
      "snippet_generalized": "ADD FOREIGN KEY ${1:entity}.${2:field} REFERENCES ${3:target_entity}(${4:target_field})$0",
      "template_specific": "ADD_FOREIGN_KEY {entity}.{field} REFERENCES {target_entity}({target_field}){cardinality_clause}",
      "template_generalized": "ADD FOREIGN KEY {entity}.{field} REFERENCES {target_entity}({target_field}){cardinality_clause}",
      "clauses": [
        {"name": "REFERENCES", "snippet": "REFERENCES ${1:target_entity}(${2:target_field})", "optional": false, "doc": "Target entity and column(s) the FK references; for composite FKs use a comma-separated list"},
        {"name": "TO", "snippet": "TO ${1:entity}", "optional": true, "doc": "Source entity (only required for the composite (col1,col2) form; single-column form takes entity from the dotted path)"},
        {"name": "WITH CARDINALITY", "values_ref": "cardinalityType", "optional": true, "doc": "Reference multiplicity"},
        {"name": "USING KEY", "snippet": "USING KEY ${1:key_name}", "optional": true, "doc": "Name an existing index/key to use"},
        {"name": "WHERE", "snippet": "WHERE ${1:cond}", "optional": true, "doc": "Optional join/predicate clause"}
      ]
    },

    "ADD_PRIMARY_KEY": {
      "category": "add",
      "specific": "ADD_PRIMARY_KEY",
      "generalized": "ADD PRIMARY KEY",
      "doc": "Add a primary key constraint",
      "syntax_specific": "ADD_PRIMARY_KEY <entity.field|(field1,field2)> [AS <dataType>] [TO <entity>]",
      "syntax_generalized": "ADD PRIMARY KEY <entity.field|(field1,field2)> [AS <dataType>] [TO <entity>]",
      "snippet_specific": "ADD_PRIMARY_KEY ${1:entity}.${2:id} AS ${3|String,Integer,Long,UUID|}$0",
      "snippet_generalized": "ADD PRIMARY KEY ${1:entity}.${2:id} AS ${3|String,Integer,Long,UUID|}$0",
      "template_specific": "ADD_PRIMARY_KEY {key_columns}{as_clause}{to_clause}",
      "template_generalized": "ADD PRIMARY KEY {key_columns}{as_clause}{to_clause}",
      "clauses": [
        {"name": "AS", "values_ref": "dataType", "optional": true, "doc": "Data type of the key"},
        {"name": "TO", "snippet": "TO ${1:entity}", "optional": true, "doc": "Target entity (legacy)"}
      ]
    },

