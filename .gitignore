# Local tool configuration
.*/
tmp*/

# Temp/test files
nul
test.js
test_output.html

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.venv/
venv/
ENV/

# IDE
.idea/
*.swp
*.swo

# ANTLR generated files (optional - uncomment if you don't want to commit them)
# grammar/*.py
# grammar/*.tokens
# grammar/*.interp

# Prevent ANTLR files accidentally generated in root directory
/SMILE.interp
/SMILE.tokens
/SMILELexer.interp
/SMILELexer.py
/SMILELexer.tokens
/SMILEListener.py
/SMILEParser.py
/SMILEVisitor.py

# Paper / thesis sources (kept local only)
paper/

# Local config — Flask secret_key, web-server config (unrelated to project), runtime logs
config/

# Reference PDFs in tests/ — documentation resources, not test inputs
tests/*.pdf
