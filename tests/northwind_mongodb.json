{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "northwind_mongodb",
  "description": "Northwind MongoDB schema with 2 root collections (orders + customers) connected by ObjectId reference. Max embedding depth: 3 levels (orders.details.product.{category,supplier}). Demonstrates cross-collection references and information equivalence with the Relational/Graph/Columnar Northwind schemas.",
  "collections": {
    "orders": {
      "bsonType": "object",
      "required": ["_id", "customer_id", "employee", "shipper", "details", "ship_destination"],
      "properties": {
        "_id": { "bsonType": "string", "description": "Primary key (order_id)" },
        "order_date": { "bsonType": "date" },
        "required_date": { "bsonType": "date" },
        "shipped_date": { "bsonType": "date" },
        "freight": { "bsonType": "double" },
        "ship_name": { "bsonType": "string" },
        "customer_id": {
          "bsonType": "string",
          "description": "Cross-collection reference to customers._id"
        },
        "ship_destination": {
          "bsonType": "object",
          "description": "Embedded shipping address (level 1)",
          "properties": {
            "ship_address": { "bsonType": "string" },
            "ship_city": { "bsonType": "string" },
            "ship_region": { "bsonType": "string" },
            "ship_postal_code": { "bsonType": "string" },
            "ship_country": { "bsonType": "string" }
          }
        },
        "employee": {
          "bsonType": "object",
          "description": "Embedded employee (level 1) with nested address (level 2)",
          "required": ["address"],
          "properties": {
            "last_name": { "bsonType": "string" },
            "first_name": { "bsonType": "string" },
            "title": { "bsonType": "string" },
            "birth_date": { "bsonType": "date" },
            "hire_date": { "bsonType": "date" },
            "phone": { "bsonType": "string" },
            "notes": { "bsonType": "string" },
            "reports_to": {
              "bsonType": "string",
              "description": "Self-reference to another employee"
            },
            "address": {
              "bsonType": "object",
              "description": "Employee address (level 2)",
              "properties": {
                "street": { "bsonType": "string" },
                "city": { "bsonType": "string" },
                "region": { "bsonType": "string" },
                "postal_code": { "bsonType": "string" },
                "country": { "bsonType": "string" }
              }
            }
          }
        },
        "shipper": {
          "bsonType": "object",
          "description": "Embedded shipper (level 1)",
          "properties": {
            "company_name": { "bsonType": "string" },
            "phone": { "bsonType": "string" }
          }
        },
        "details": {
          "bsonType": "array",
          "description": "Array of order line items (level 1)",
          "items": {
            "bsonType": "object",
            "required": ["product"],
            "properties": {
              "unit_price": { "bsonType": "double" },
              "quantity": { "bsonType": "int" },
              "discount": { "bsonType": "double" },
              "product": {
                "bsonType": "object",
                "description": "Embedded product (level 2)",
                "required": ["category", "supplier"],
                "properties": {
                  "product_name": { "bsonType": "string" },
                  "unit_price": { "bsonType": "double" },
                  "units_in_stock": { "bsonType": "int" },
                  "discontinued": { "bsonType": "bool" },
                  "quantity_per_unit": { "bsonType": "string" },
                  "category": {
                    "bsonType": "object",
                    "description": "Embedded category (level 3 — leaf)",
                    "properties": {
                      "category_name": { "bsonType": "string" },
                      "description": { "bsonType": "string" }
                    }
                  },
                  "supplier": {
                    "bsonType": "object",
                    "description": "Embedded supplier (level 3 — leaf, address fields flattened to keep depth=3)",
                    "properties": {
                      "company_name": { "bsonType": "string" },
                      "contact_name": { "bsonType": "string" },
                      "contact_title": { "bsonType": "string" },
                      "phone": { "bsonType": "string" },
                      "fax": { "bsonType": "string" },
                      "street": { "bsonType": "string" },
                      "city": { "bsonType": "string" },
                      "region": { "bsonType": "string" },
                      "postal_code": { "bsonType": "string" },
                      "country": { "bsonType": "string" }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "customers": {
      "bsonType": "object",
      "required": ["_id", "address"],
      "properties": {
        "_id": { "bsonType": "string", "description": "Primary key (customer_id)" },
        "company_name": { "bsonType": "string" },
        "contact_name": { "bsonType": "string" },
        "contact_title": { "bsonType": "string" },
        "phone": { "bsonType": "string" },
        "fax": { "bsonType": "string" },
        "address": {
          "bsonType": "object",
          "description": "Customer address (level 1)",
          "properties": {
            "street": { "bsonType": "string" },
            "city": { "bsonType": "string" },
            "region": { "bsonType": "string" },
            "postal_code": { "bsonType": "string" },
            "country": { "bsonType": "string" }
          }
        }
      }
    }
  }
}
