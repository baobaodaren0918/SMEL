-- Grammar completeness test: exercise every SMILE operation that no other
-- test in tests/specific or tests/generalized invokes.
--
-- Goal: prove every operation declared in the grammar reaches its handler
--       and returns success (handler doesn't raise / doesn't return False).
-- Each op below is annotated with [#N → opname] for cross-reference.

EVOLUTION grammar_completeness:1.0
FROM RELATIONAL TO RELATIONAL
USING grammar_completeness_schema VERSION 1.0 TO 2.0

-- [1 → ADD_UNIQUE_KEY] customers.email becomes a unique key
ADD_UNIQUE_KEY customers.email

-- [2 → DELETE_UNIQUE_KEY] undo the previous unique
DELETE_UNIQUE_KEY email FROM customers

-- [3 → COPY_PROPERTY] duplicate customers.email onto orders (orders gains an "email" column)
COPY_PROPERTY email FROM customers TO orders

-- [4 → MOVE_PROPERTY] take products.sku and re-home it on customers
MOVE_PROPERTY sku FROM products TO customers

-- [5 → COPY_ENTITY] duplicate customers as customers_archive (full schema copy)
COPY_ENTITY customers AS customers_archive

-- [6 → RECARD] change orders.customer_id reference from default to ZERO_TO_MANY
RECARD orders.customer_id TO ZERO_TO_MANY

-- [7 → CAST_ENTITY] flip products from RELATIONAL to DOCUMENT — kind_locked = True
CAST_ENTITY products TO DOCUMENT

-- [8 → DELETE_EMBEDDED] requires an embedded to exist first → ADD then DELETE
ADD_EMBEDDED address TO customers
DELETE_EMBEDDED customers.address

-- [9 → DELETE_LABEL] requires a label to exist first → ADD then DELETE
ADD_LABEL Premium TO customers
DELETE_LABEL Premium FROM customers

-- [10 → CAST_PROPERTY] change orders.amount data type Decimal → Integer
CAST_PROPERTY orders.amount TO Integer

-- [11 → WIND] convert customers.full_name scalar into an array
WIND customers.full_name

-- [12 → UNWIND] expand the (now-array) customers.full_name back out (in-place mode)
UNWIND customers.full_name

-- [13 → ADD_CONSTRAINT (EXISTENCE branch)] tighten orders.amount to NOT NULL
-- post-hoc — exercises the AS EXISTENCE body. The REFERENCE LOGICAL and
-- CHECK branches are already exercised by the to-Mongo Northwind scripts
-- (REFERENCE LOGICAL) and CHECK is intentionally not part of the Northwind
-- benchmark (it is a supplementary feature).
ADD_CONSTRAINT orders.amount AS EXISTENCE

-- [14 → DELETE_CONSTRAINT] undo the EXISTENCE constraint just added
DELETE_CONSTRAINT orders.amount
