-- SMEL Northwind: MongoDB V1 -> MongoDB V2 (Generalized Operations Version)
-- Same-model Schema Evolution: Document -> Document
-- V2 Business Scenario: E-commerce platform modernization
--
-- Structural changes:
--   FLATTEN:       Flatten category sub-object into product (denormalize, reduce L3->L2)
--   UNFLATTEN:     Group customer contact fields into contacts sub-object (reorganize)
--   ADD_EMBEDDED:  Add territories array to employee with nested region (sales territory tracking)

MIGRATION northwind_mongo1_to_mongo2:1.0
FROM DOCUMENT TO DOCUMENT
USING northwind_schema:1

-- ============================================
-- Meta V1 (after Reverse Engineering of northwind_mongodb.json)
-- ============================================
-- orders (root) { _id [PK], order_date, required_date, shipped_date, freight, ship_name }
--   embedded: ship_destination { ship_address, ship_city, ship_region, ship_postal_code, ship_country }
--   embedded: customer { company_name, contact_name, contact_title, phone, fax }
--     embedded: address { street, city, region, postal_code, country }           [L2]
--   embedded: employee { last_name, first_name, title, birth_date, hire_date, phone, notes, reports_to }
--     embedded: address { street, city, region, postal_code, country }           [L2]
--   embedded: shipper { company_name, phone }
--   embedded: details[] (ONE_TO_MANY)
--     embedded: product { product_name, unit_price, units_in_stock, discontinued, quantity_per_unit }
--       embedded: category { category_name, description }               [L3]
--       embedded: supplier { company_name, contact_name, contact_title, phone, fax }
--         embedded: address { street, city, region, postal_code, country }      [L4]

-- ============================================
-- Phase 1: FLATTEN category into product (structural -- reduce nesting)
-- Document equivalent of MERGE: L3 -> L2, category sub-object disappears
-- ============================================
FLATTEN orders.details.product.category
RENAME ATTRIBUTE category_category_name TO category_name IN product
RENAME ATTRIBUTE category_description TO description IN product

-- ============================================
-- Phase 2: UNFLATTEN customer contact fields into contacts sub-object (structural)
-- Document equivalent of SPLIT: group contact person fields into sub-object
-- ============================================
UNFLATTEN customer:contact_name, contact_title, phone, fax AS contacts

-- ============================================
-- Phase 3: ADD territories array to employee (new embedded array)
-- Document equivalent of ADD_ENTITY + M:N: employee gets territories[]
-- ============================================
ADD EMBEDDED territories TO employee WITH CARDINALITY ONE_TO_MANY
ADD ATTRIBUTE territory_id TO territories WITH TYPE String
ADD ATTRIBUTE territory_description TO territories WITH TYPE String

-- ============================================
-- Phase 4: ADD region inside territories (nested embedded)
-- Document equivalent of FK relationship: territory contains its region
-- ============================================
ADD EMBEDDED region TO territories
ADD ATTRIBUTE region_id TO region WITH TYPE String
ADD ATTRIBUTE region_description TO region WITH TYPE String

-- ============================================
-- Phase 5: employee -- simplify + ADD
-- ============================================
DELETE ATTRIBUTE employee.birth_date
DELETE ATTRIBUTE employee.notes
ADD ATTRIBUTE email TO employee WITH TYPE String

-- ============================================
-- Phase 6: product + orders -- RENAME + ADD
-- ============================================
RENAME ATTRIBUTE product_name TO name IN product
RENAME ATTRIBUTE freight TO shipping_cost IN orders
ADD ATTRIBUTE status TO orders WITH TYPE String

-- ============================================
-- Final Meta V2 (max L4 nesting):
-- orders { _id [PK], order_date, required_date, shipped_date, shipping_cost, ship_name, status }
--   ship_destination { ship_address, ship_city, ship_region, ship_postal_code, ship_country }
--   customer { company_name, address { street, city, region, postal_code, country },
--              contacts { contact_name, contact_title, phone, fax } }
--   employee { last_name, first_name, title, hire_date, email, phone, reports_to,
--              address { street, city, region, postal_code, country },
--              territories[] { territory_id, territory_description,
--                              region { region_id, region_description } } }
--   shipper { company_name, phone }
--   details[] {
--     unit_price, quantity, discount,
--     product { name, unit_price, units_in_stock, discontinued, quantity_per_unit,
--               category_name, description,
--               supplier { company_name, contact_name, contact_title, phone, fax,
--                          address { street, city, region, postal_code, country } } }
--   }
-- ============================================
