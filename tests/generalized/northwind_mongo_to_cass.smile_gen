-- SMILE Northwind: MongoDB -> Cassandra (Generalized Operations Version)
-- 2 Document Collections (orders + customers) -> 8 Wide-column Tables

MIGRATION northwind_mongo_to_cass:1.0
FROM DOCUMENT TO COLUMNAR
USING adapted_northwind_schema VERSION 1

-- Step 1: Rename PKs from Mongo _id
RENAME PROPERTY _id TO order_id IN orders
RENAME PROPERTY _id TO customer_id IN customers

-- Mongo source carries a logical cross-collection reference orders.customer_id
-- -> customers. Cassandra denormalised tables don't model this, drop it so the
-- meta model matches the target.
DELETE CONSTRAINT orders.customer_id

-- Step 2: UNNEST details[] -> order_details
UNNEST orders.details:unit_price, quantity, discount, product{product_name, unit_price, units_in_stock, discontinued, quantity_per_unit, category{category_name, description}, supplier{company_name, contact_name, contact_title, phone, fax, street, city, region, postal_code, country}} AS order_details WITH orders.order_id TO order_details.order_id

-- Step 3: UNNEST employee -> employees
UNNEST orders.employee:last_name, first_name, title, birth_date, hire_date, phone, notes, reports_to, address{street, city, region, postal_code, country} AS employees WITH orders.order_id TO employees.order_id
DELETE PROPERTY employees.order_id
ADD KEY employees.employee_id AS String
ADD PROPERTY employee_id TO orders WITH TYPE String

-- Step 4: UNNEST shipper -> shippers
UNNEST orders.shipper:company_name, phone AS shippers WITH orders.order_id TO shippers.order_id
DELETE PROPERTY shippers.order_id
ADD KEY shippers.shipper_id AS String
ADD PROPERTY shipper_id TO orders WITH TYPE String

-- Step 5: UNNEST product -> products (supplier carries flat address fields)
UNNEST order_details.product:product_name, unit_price, units_in_stock, discontinued, quantity_per_unit, category{category_name, description}, supplier{company_name, contact_name, contact_title, phone, fax, street, city, region, postal_code, country} AS products WITH order_details.order_id TO products.order_id
DELETE PROPERTY products.order_id
ADD KEY products.product_id AS String
ADD PROPERTY product_id TO order_details WITH TYPE String

-- Step 6: UNNEST supplier -> suppliers (no FLATTEN — supplier already had flat address)
UNNEST products.supplier:company_name, contact_name, contact_title, phone, fax, street, city, region, postal_code, country AS suppliers WITH products.product_id TO suppliers.product_id
DELETE PROPERTY suppliers.product_id
ADD KEY suppliers.supplier_id AS String
ADD PROPERTY supplier_id TO products WITH TYPE String

-- Step 7: UNNEST category -> categories
UNNEST products.category:category_name, description AS categories WITH products.product_id TO categories.product_id
DELETE PROPERTY categories.product_id
ADD KEY categories.category_id AS String
ADD PROPERTY category_id TO products WITH TYPE String

-- Step 8: FLATTEN nested address sub-objects (Cass uses flat columns)
FLATTEN customers.address
RENAME PROPERTY address_street TO street IN customers
RENAME PROPERTY address_city TO city IN customers
RENAME PROPERTY address_region TO region IN customers
RENAME PROPERTY address_postal_code TO postal_code IN customers
RENAME PROPERTY address_country TO country IN customers

FLATTEN employees.address
RENAME PROPERTY address_street TO street IN employees
RENAME PROPERTY address_city TO city IN employees
RENAME PROPERTY address_region TO region IN employees
RENAME PROPERTY address_postal_code TO postal_code IN employees
RENAME PROPERTY address_country TO country IN employees

FLATTEN orders.ship_destination
RENAME PROPERTY ship_destination_ship_address TO ship_address IN orders
RENAME PROPERTY ship_destination_ship_city TO ship_city IN orders
RENAME PROPERTY ship_destination_ship_region TO ship_region IN orders
RENAME PROPERTY ship_destination_ship_postal_code TO ship_postal_code IN orders
RENAME PROPERTY ship_destination_ship_country TO ship_country IN orders

-- Step 9: CAST simple PKs to PARTITION KEY
CAST CONSTRAINT categories.category_id TO PARTITION KEY
CAST CONSTRAINT suppliers.supplier_id TO PARTITION KEY
CAST CONSTRAINT shippers.shipper_id TO PARTITION KEY
CAST CONSTRAINT employees.employee_id TO PARTITION KEY
CAST CONSTRAINT customers.customer_id TO PARTITION KEY

-- Step 10: Restructure complex-table keys
DELETE PRIMARY KEY product_id FROM products
ADD PARTITION KEY (category_id, supplier_id) TO products
ADD CLUSTERING KEY product_id TO products

DELETE PRIMARY KEY order_id FROM orders
ADD PARTITION KEY customer_id TO orders
ADD CLUSTERING KEY order_date TO orders
ADD CLUSTERING KEY order_id TO orders

ADD PARTITION KEY (order_id, product_id) TO order_details
