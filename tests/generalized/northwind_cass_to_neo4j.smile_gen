-- SMILE Northwind: Cassandra -> Neo4j (Generalized Operations Version)
-- Cross-model Schema Migration: Columnar -> Graph
-- Direction: northwind_cassandra.cql -> northwind_neo4j.cypher
--
-- Pipeline: Source Cassandra -> Reverse Engineering -> Meta V1 (Columnar)
--           -> SMILE Operations (this script) -> Meta V2 (Graph)
--           -> Forward Engineering -> Target Neo4j
--
-- Operation Semantics:
--   DELETE PARTITION KEY:  Remove Cassandra partition key before restructuring
--   DELETE CLUSTERING KEY: Remove Cassandra clustering key
--   ADD UNIQUE KEY:        Add staging UNIQUE constraint (kind="unique", is_primary_key=False).
--                          Step 4 CAST CONSTRAINT TO NODE KEY elevates it to the Neo4j
--                          NODE_KEY subtype — the real Graph identity. ADD UNIQUE KEY
--                          alone does NOT create graph identity.
--   ADD CONSTRAINT ... AS REFERENCE: Declare a paradigm-neutral logical
--                         reference (Cassandra has no FK; this is *not*
--                         ADD FOREIGN KEY which would assert enforcement).
--                         Cardinality flows via the relationship trace.
--   DELETE PROPERTY:      Remove FK-like attribute (replaced by graph edge);
--                         its trace hook also captures the logical Reference.
--   ADD ENTITY:            Add relationship type from source to target node (graph edge)
--   TRANSFORM:             Convert entity (wide-column table) to relationship (graph edge)
--   RENAME ENTITY:         Rename relationship type after TRANSFORM
--   CAST CONSTRAINT:       Cast partition key to graph node key

MIGRATION northwind_cass_to_neo4j:1.0
FROM COLUMNAR TO GRAPH
USING adapted_northwind_schema VERSION 1

-- ============================================
-- Source: Cassandra Wide-column Tables (8 tables)
-- ============================================
-- categories     (category_id [PARTITION], category_name, description)
-- suppliers      (supplier_id [PARTITION], company_name, contact_name, contact_title, phone, fax, street, city, region, postal_code, country)
-- shippers       (shipper_id [PARTITION], company_name, phone)
-- employees      (employee_id [PARTITION], last_name, first_name, title, birth_date, hire_date, phone, notes, street, city, region, postal_code, country, reports_to)
-- customers      (customer_id [PARTITION], company_name, contact_name, contact_title, phone, fax, street, city, region, postal_code, country)
-- products       (category_id [PARTITION], supplier_id [PARTITION], product_id [CLUSTERING], product_name, unit_price, units_in_stock, discontinued, quantity_per_unit)
-- orders         (customer_id [PARTITION], order_date [CLUSTERING], order_id [CLUSTERING], required_date, shipped_date, freight, ship_name, ship_address, ship_city, ship_region, ship_postal_code, ship_country, employee_id, shipper_id)
-- order_details  (order_id [PARTITION], product_id [PARTITION], unit_price, quantity, discount)

-- ============================================
-- Target: Neo4j Graph (7 nodes, 7 relationships)
-- ============================================
-- Nodes:
--   categories:  { category_id [PK], category_name, description }
--   suppliers:   { supplier_id [PK], company_name, contact_name, contact_title, phone, fax, street, city, region, postal_code, country }
--   shippers:    { shipper_id [PK], company_name, phone }
--   employees:   { employee_id [PK], last_name, first_name, title, birth_date, hire_date, phone, notes, street, city, region, postal_code, country }
--   customers:   { customer_id [PK], company_name, contact_name, contact_title, phone, fax, street, city, region, postal_code, country }
--   products:    { product_id [PK], product_name, unit_price, units_in_stock, discontinued, quantity_per_unit }
--   orders:      { order_id [PK], order_date, required_date, shipped_date, freight, ship_name, ship_address, ship_city, ship_region, ship_postal_code, ship_country }
-- Relationships:
--   REPORTS_TO  (employees -> employees)
--   SUPPLIES    (suppliers -> products)
--   PART_OF     (products -> categories)
--   PURCHASED   (customers -> orders)
--   SOLD        (employees -> orders)
--   SHIPPED_VIA (orders -> shippers)
--   CONTAINS    (orders -> products) with properties { unit_price, quantity, discount }

-- ============================================
-- Step 1: Restructure keys - remove Cassandra partition/clustering for complex tables
-- ============================================

-- products: partition + clustering -> simple PK
-- Cassandra: category_id [PARTITION], supplier_id [PARTITION], product_id [CLUSTERING]
-- Graph: product_id [PK]
DELETE PARTITION KEY (category_id, supplier_id) FROM products
DELETE CLUSTERING KEY product_id FROM products
ADD UNIQUE KEY product_id TO products
-- Result:
-- products: { product_id [PK], product_name, unit_price, units_in_stock, discontinued, quantity_per_unit, supplier_id, category_id }

-- orders: partition + clustering -> simple PK
-- Cassandra: customer_id [PARTITION], order_date [CLUSTERING], order_id [CLUSTERING]
-- Graph: order_id [PK]
DELETE PARTITION KEY customer_id FROM orders
DELETE CLUSTERING KEY order_date FROM orders
DELETE CLUSTERING KEY order_id FROM orders
ADD UNIQUE KEY order_id TO orders
-- Result:
-- orders: { order_id [PK], order_date, required_date, shipped_date, freight, ship_name, ship_address, ship_city, ship_region, ship_postal_code, ship_country, customer_id, employee_id, shipper_id }

-- order_details: remove partition + clustering (no PK added -- will become relationship)
-- Cassandra: order_id [PARTITION], product_id [PARTITION]
DELETE PARTITION KEY (order_id, product_id) FROM order_details
-- Result:
-- order_details: { order_id, product_id, unit_price, quantity, discount }

-- ============================================
-- Step 2: Delete FK-like attributes and add relationships
-- ============================================

-- employees self-reference: reports_to column -> REPORTS_TO relationship
-- Use ADD CONSTRAINT REFERENCE (not ADD FOREIGN KEY) because
-- Cassandra has no FK paradigm; this declares the logical reference whose
-- cardinality flows via the relationship trace into the new graph Edge.
ADD CONSTRAINT employees.reports_to AS REFERENCE TO employees(employee_id) WITH CARDINALITY ZERO_TO_ONE
DELETE PROPERTY employees.reports_to
ADD ENTITY REPORTS_TO FROM employees TO employees
-- Result:
-- employees: { employee_id [PK], last_name, first_name, title, birth_date, hire_date, phone, notes, street, city, region, postal_code, country }
-- + REPORTS_TO relationship (employees -> employees)

-- products -> supplier: supplier_id column -> SUPPLIES relationship
ADD CONSTRAINT products.supplier_id AS REFERENCE TO suppliers(supplier_id) WITH CARDINALITY ONE_TO_ONE
DELETE PROPERTY products.supplier_id
ADD ENTITY SUPPLIES FROM suppliers TO products
-- Result:
-- products: { product_id [PK], product_name, unit_price, units_in_stock, discontinued, quantity_per_unit, category_id }
-- + SUPPLIES relationship (suppliers -> products)

-- products -> category: category_id column -> PART_OF relationship
ADD CONSTRAINT products.category_id AS REFERENCE TO categories(category_id) WITH CARDINALITY ONE_TO_ONE
DELETE PROPERTY products.category_id
ADD ENTITY PART_OF FROM products TO categories
-- Result:
-- products: { product_id [PK], product_name, unit_price, units_in_stock, discontinued, quantity_per_unit }

-- orders -> customer: customer_id column -> PURCHASED relationship
ADD CONSTRAINT orders.customer_id AS REFERENCE TO customers(customer_id) WITH CARDINALITY ONE_TO_ONE
DELETE PROPERTY orders.customer_id
ADD ENTITY PURCHASED FROM customers TO orders
-- Result:
-- orders: { order_id [PK], order_date, required_date, shipped_date, freight, ship_name, ship_address, ship_city, ship_region, ship_postal_code, ship_country, employee_id, shipper_id }
-- + PURCHASED relationship (customers -> orders)

-- orders -> employee: employee_id column -> SOLD relationship
ADD CONSTRAINT orders.employee_id AS REFERENCE TO employees(employee_id) WITH CARDINALITY ONE_TO_ONE
DELETE PROPERTY orders.employee_id
ADD ENTITY SOLD FROM employees TO orders
-- Result:
-- orders: { order_id [PK], order_date, required_date, shipped_date, freight, ship_name, ship_address, ship_city, ship_region, ship_postal_code, ship_country, shipper_id }
-- + SOLD relationship (employees -> orders)

-- orders -> shipper: shipper_id column -> SHIPPED_VIA relationship
ADD CONSTRAINT orders.shipper_id AS REFERENCE TO shippers(shipper_id) WITH CARDINALITY ONE_TO_ONE
DELETE PROPERTY orders.shipper_id
ADD ENTITY SHIPPED_VIA FROM orders TO shippers
-- Result:
-- orders: { order_id [PK], order_date, required_date, shipped_date, freight, ship_name, ship_address, ship_city, ship_region, ship_postal_code, ship_country }

-- ============================================
-- Step 3: TRANSFORM order_details to CONTAINS relationship
-- ============================================
-- order_details has: order_id, product_id, unit_price, quantity, discount
-- Remove FK-like columns, then transform entity to relationship.
-- Remaining attributes (unit_price, quantity, discount) become relationship properties.
DELETE PROPERTY order_details.order_id
DELETE PROPERTY order_details.product_id
TRANSFORM order_details INTO RELATIONSHIP FROM orders TO products
RENAME ENTITY order_details TO CONTAINS
-- Result:
-- order_details table removed; CONTAINS relationship created:
-- CONTAINS (orders -> products) with properties: { unit_price, quantity, discount }
-- Note: TRANSFORM creates relationship with entity name "order_details",
--       then RENAME ENTITY renames it to match Neo4j convention "CONTAINS".

-- ============================================
-- Step 4: CAST Partition Keys to Neo4j Node Keys
-- ============================================
-- Simple tables: PARTITION KEY -> NODE KEY
CAST CONSTRAINT categories.category_id TO NODE KEY
CAST CONSTRAINT suppliers.supplier_id TO NODE KEY
CAST CONSTRAINT shippers.shipper_id TO NODE KEY
CAST CONSTRAINT employees.employee_id TO NODE KEY
CAST CONSTRAINT customers.customer_id TO NODE KEY
-- Complex tables: staging UNIQUE constraint (from ADD UNIQUE KEY) -> NODE KEY
CAST CONSTRAINT products.product_id TO NODE KEY
CAST CONSTRAINT orders.order_id TO NODE KEY

-- ============================================
-- Final Meta V2 (7 nodes, 7 relationship types):
-- ============================================
-- categories:  { category_id [PK], category_name, description }
-- suppliers:   { supplier_id [PK], company_name, contact_name, contact_title, phone, fax, street, city, region, postal_code, country }
-- shippers:    { shipper_id [PK], company_name, phone }
-- employees:   { employee_id [PK], last_name, first_name, title, birth_date, hire_date, phone, notes, street, city, region, postal_code, country }
-- customers:   { customer_id [PK], company_name, contact_name, contact_title, phone, fax, street, city, region, postal_code, country }
-- products:    { product_id [PK], product_name, unit_price, units_in_stock, discontinued, quantity_per_unit }
-- orders:      { order_id [PK], order_date, required_date, shipped_date, freight, ship_name, ship_address, ship_city, ship_region, ship_postal_code, ship_country }
-- REPORTS_TO  (employees -> employees)
-- SUPPLIES    (suppliers -> products)
-- PART_OF     (products -> categories)
-- PURCHASED   (customers -> orders)
-- SOLD        (employees -> orders)
-- SHIPPED_VIA (orders -> shippers)
-- CONTAINS    (orders -> products) with properties { unit_price, quantity, discount }
-- [order_details TRANSFORMED to CONTAINS relationship]
-- ============================================

-- ============================================
-- Operation Summary (30 steps, 9 operation types):
--   DELETE PARTITION KEY:  3    DELETE CLUSTERING KEY: 3
--   ADD UNIQUE KEY:        2    ADD CONSTRAINT(REF):   6
--   DELETE PROPERTY:       8    ADD ENTITY(edge):      6
--   TRANSFORM:             1    RENAME ENTITY:         1
--   CAST CONSTRAINT:       5
--   EntityKind auto-convert: WIDE_COLUMN_TABLE -> VERTEX (all 8 entities)
-- ============================================
