-- SMILE Northwind: PostgreSQL -> MongoDB (Generalized Operations Version)
-- 8 Normalized Tables (3NF) -> 2 Document Collections (orders + customers, max L3 nesting)
--
-- Operation Semantics:
--   NEST:      Embed separate table into parent as nested object (reverse of UNNEST)
--   UNFLATTEN: Combine flat fields into nested object (reverse of FLATTEN)

MIGRATION northwind_pg_to_mongo:1.0
FROM RELATIONAL TO DOCUMENT
USING adapted_northwind_schema VERSION 1

-- ============================================
-- Source: PostgreSQL 3NF Tables (8 tables) — see specific variant for full description
-- Target: MongoDB 2 collections (orders + customers), max depth 3
--   Root 1: orders { _id, ..., customer_id (REF -> customers._id),
--                    ship_destination{}, employee{address{}}, shipper{}, details[]{product{category{}, supplier{flat addr}}} }
--   Root 2: customers { _id, company_name, address{} }
-- ============================================

-- Step 1: UNFLATTEN address only where target has nested address (NOT suppliers — supplier stays flat at L3)
UNFLATTEN customers:street, city, region, postal_code, country AS address
UNFLATTEN employees:street, city, region, postal_code, country AS address
UNFLATTEN orders:ship_address, ship_city, ship_region, ship_postal_code, ship_country AS ship_destination

-- Step 2: NEST categories into products (L3 leaf)
NEST categories:category_name, description IN products.category WHERE products.category_id = categories.category_id
DELETE ENTITY categories

-- Step 3: NEST suppliers into products (L3 leaf, with flat address fields)
NEST suppliers:company_name, contact_name, contact_title, phone, fax, street, city, region, postal_code, country IN products.supplier WHERE products.supplier_id = suppliers.supplier_id
DELETE ENTITY suppliers

-- Step 4: NEST products into order_details (L2)
NEST products:product_name, unit_price, units_in_stock, discontinued, quantity_per_unit, category{category_name, description}, supplier{company_name, contact_name, contact_title, phone, fax, street, city, region, postal_code, country} IN order_details.product WHERE order_details.product_id = products.product_id
DELETE ENTITY products

-- Step 5: NEST shippers into orders (L1)
NEST shippers:company_name, phone IN orders.shipper WHERE orders.shipper_id = shippers.shipper_id
DELETE ENTITY shippers

-- Step 6: NEST employees into orders (L1, with nested address at L2)
NEST employees:last_name, first_name, title, birth_date, hire_date, phone, notes, reports_to, address{street, city, region, postal_code, country} IN orders.employee WHERE orders.employee_id = employees.employee_id
-- Self-reference: reports_to points at another employee in the same nested collection.
ADD CONSTRAINT orders.employee.reports_to AS REFERENCE LOGICAL TO orders.employee(employee_id) WITH CARDINALITY ZERO_TO_ONE
DELETE ENTITY employees

-- Step 7: NEST order_details into orders.details[] (L1 array)
NEST order_details:unit_price, quantity, discount, product{product_name, unit_price, units_in_stock, discontinued, quantity_per_unit, category{category_name, description}, supplier{company_name, contact_name, contact_title, phone, fax, street, city, region, postal_code, country}} IN orders.details WHERE order_details.order_id = orders.order_id
DELETE ENTITY order_details

-- Step 8: customers stays as Root 2 — promote PK to _id
RENAME PROPERTY customer_id TO _id IN customers
CAST CONSTRAINT customers._id TO DOCUMENT_ID

-- Step 9: orders PK -> _id; customer_id stays as cross-collection ref string
RENAME PROPERTY order_id TO _id IN orders
CAST CONSTRAINT orders._id TO DOCUMENT_ID
DELETE FOREIGN KEY orders.customer_id
ADD CONSTRAINT orders.customer_id AS REFERENCE LOGICAL TO customers(_id) WITH CARDINALITY ONE_TO_MANY
