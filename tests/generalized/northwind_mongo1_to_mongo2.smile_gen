-- SMILE Northwind: MongoDB V1 -> MongoDB V2 (Generalized Operations Version)
-- Same-model Schema Evolution: Document -> Document
-- V1 / V2 are both 2-collection layouts (orders + customers, max depth 3).
--
-- V2 Business Scenario: E-commerce platform modernization
--
-- Structural changes:
--   FLATTEN:       Flatten category sub-object into product (denormalize, L3 -> L2)
--   UNFLATTEN:     Group customers contact fields into a contacts sub-object
--   ADD EMBEDDED:  Add territories[] to employee with nested region (sales territory tracking)

EVOLUTION northwind_mongo1_to_mongo2:1.0
FROM DOCUMENT TO DOCUMENT
USING adapted_northwind_schema VERSION 1 TO 2

-- ============================================
-- Meta V1 (after Reverse Engineering of northwind_mongodb.json — 2 roots)
-- ============================================
-- Root 1: orders { _id [PK], order_date, required_date, shipped_date, freight, ship_name, customer_id (REF) }
--   embedded: ship_destination { ship_address, ship_city, ship_region, ship_postal_code, ship_country }
--   embedded: employee { last_name, first_name, title, birth_date, hire_date, phone, notes, reports_to }
--     embedded: address { street, city, region, postal_code, country }                              [L2]
--   embedded: shipper { company_name, phone }
--   embedded: details[] (ONE_TO_MANY)
--     embedded: product { product_name, unit_price, units_in_stock, discontinued, quantity_per_unit }
--       embedded: category { category_name, description }                                            [L3]
--       embedded: supplier { company_name, contact_name, contact_title, phone, fax,
--                            street, city, region, postal_code, country (flat address) }            [L3]
-- Root 2: customers { _id [PK], company_name, contact_name, contact_title, phone, fax }
--   embedded: address { street, city, region, postal_code, country }                                 [L1]

-- ============================================
-- Phase 1: FLATTEN category into product (structural -- reduce nesting)
-- L3 -> L2: category sub-object disappears
-- ============================================
FLATTEN orders.details.product.category
RENAME PROPERTY category_category_name TO category_name IN product
RENAME PROPERTY category_description TO description IN product

-- ============================================
-- Phase 2: UNFLATTEN customers contact fields into contacts sub-object
-- Operates on Root 2 (customers collection).
-- ============================================
UNFLATTEN customers:contact_name, contact_title, phone, fax AS contacts

-- ============================================
-- Phase 3: ADD territories array to employee
-- ============================================
ADD EMBEDDED territories TO employee WITH CARDINALITY ONE_TO_MANY
ADD PROPERTY territory_id TO territories WITH TYPE String
ADD PROPERTY territory_description TO territories WITH TYPE String

-- ============================================
-- Phase 4: ADD sales_region inside territories (keeps max depth = 3)
-- (Named sales_region to disambiguate from address.region.)
-- ============================================
ADD EMBEDDED sales_region TO territories
ADD PROPERTY region_id TO sales_region WITH TYPE String
ADD PROPERTY region_description TO sales_region WITH TYPE String

-- ============================================
-- Phase 5: employee -- simplify + ADD email
-- ============================================
DELETE PROPERTY employee.birth_date
DELETE PROPERTY employee.notes
ADD PROPERTY email TO employee WITH TYPE String

-- ============================================
-- Phase 6: product + orders -- RENAME + ADD
-- ============================================
RENAME PROPERTY product_name TO name IN product
RENAME PROPERTY freight TO shipping_cost IN orders
ADD PROPERTY status TO orders WITH TYPE String

-- ============================================
-- Final Meta V2 (max L3 nesting, 2 roots — see specific variant for details)
-- ============================================
