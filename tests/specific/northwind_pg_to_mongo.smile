-- SMILE Northwind: PostgreSQL -> MongoDB (Specific Operations Version)
-- 8 Normalized Tables (3NF) -> 2 Document Collections (orders + customers, max L3 nesting)
-- Direction: Normalized (3NF) -> Partial Denormalization (2 roots + ObjectId ref)
--
-- Operation Semantics:
--   NEST:      Embed separate table into parent as nested object (reverse of UNNEST)
--   UNFLATTEN: Combine flat fields into nested object (reverse of FLATTEN)

MIGRATION northwind_pg_to_mongo:1.0
FROM RELATIONAL TO DOCUMENT
USING adapted_northwind_schema VERSION 1

-- ============================================
-- Source: PostgreSQL 3NF Tables (8 tables)
-- ============================================
-- categories (category_id [PK], category_name, description)
-- suppliers (supplier_id [PK], company_name, contact_name, contact_title, phone, fax, street, city, region, postal_code, country)
-- shippers (shipper_id [PK], company_name, phone)
-- employees (employee_id [PK], last_name, first_name, title, birth_date, hire_date, phone, notes, street, city, region, postal_code, country, reports_to [FK->employees])
-- customers (customer_id [PK], company_name, contact_name, contact_title, phone, fax, street, city, region, postal_code, country)
-- products (product_id [PK], product_name, unit_price, units_in_stock, discontinued, quantity_per_unit, supplier_id [FK->suppliers], category_id [FK->categories])
-- orders (order_id [PK], order_date, required_date, shipped_date, freight, ship_name, ship_address, ship_city, ship_region, ship_postal_code, ship_country, customer_id [FK->customers], employee_id [FK->employees], shipper_id [FK->shippers])
-- order_details (order_id [PK,FK->orders], product_id [PK,FK->products], unit_price, quantity, discount)

-- ============================================
-- Target: MongoDB 2 collections, max depth 3
-- ============================================
-- Root 1: orders { _id, order_date, ..., customer_id (REF -> customers._id),
--   ship_destination{...}, employee{..., address{...}}, shipper{...},
--   details[]{ ..., product{..., category{...}, supplier{... flat address ...}} } }
-- Root 2: customers { _id, company_name, address{...} }

-- ============================================
-- Step 1: UNFLATTEN address fields where the target schema has nested address
--   - customers (Root 2: address is L1 sub-object)
--   - employees (will be embedded in orders.employee, address at L2)
--   - orders ship_* fields -> ship_destination L1 sub-object
-- NOT UNFLATTEN suppliers (target keeps supplier address flat at L3 to cap depth)
-- ============================================
UNFLATTEN customers:street, city, region, postal_code, country AS address
UNFLATTEN employees:street, city, region, postal_code, country AS address
UNFLATTEN orders:ship_address, ship_city, ship_region, ship_postal_code, ship_country AS ship_destination

-- ============================================
-- Step 2: NEST categories into products (L3 leaf)
-- ============================================
NEST categories:category_name, description IN products.category WHERE products.category_id = categories.category_id
DELETE_ENTITY categories

-- ============================================
-- Step 3: NEST suppliers into products (L3 leaf, supplier keeps flat address)
-- ============================================
NEST suppliers:company_name, contact_name, contact_title, phone, fax, street, city, region, postal_code, country IN products.supplier WHERE products.supplier_id = suppliers.supplier_id
DELETE_ENTITY suppliers

-- ============================================
-- Step 4: NEST products into order_details (L2)
-- ============================================
NEST products:product_name, unit_price, units_in_stock, discontinued, quantity_per_unit, category{category_name, description}, supplier{company_name, contact_name, contact_title, phone, fax, street, city, region, postal_code, country} IN order_details.product WHERE order_details.product_id = products.product_id
DELETE_ENTITY products

-- ============================================
-- Step 5: NEST shippers into orders (L1)
-- ============================================
NEST shippers:company_name, phone IN orders.shipper WHERE orders.shipper_id = shippers.shipper_id
DELETE_ENTITY shippers

-- ============================================
-- Step 6: NEST employees into orders (L1, with nested address at L2)
-- ============================================
NEST employees:last_name, first_name, title, birth_date, hire_date, phone, notes, reports_to, address{street, city, region, postal_code, country} IN orders.employee WHERE orders.employee_id = employees.employee_id
-- The nested employee carries reports_to as a self-reference (each manager is
-- another employee inside the same denormalised collection). NEST itself does
-- not promote the column to a Reference, so re-declare the logical self-ref
-- explicitly here.
ADD_CONSTRAINT orders.employee.reports_to AS REFERENCE LOGICAL TO orders.employee(employee_id) WITH CARDINALITY ZERO_TO_ONE
DELETE_ENTITY employees

-- ============================================
-- Step 7: NEST order_details into orders.details[] (L1 array)
-- ============================================
NEST order_details:unit_price, quantity, discount, product{product_name, unit_price, units_in_stock, discontinued, quantity_per_unit, category{category_name, description}, supplier{company_name, contact_name, contact_title, phone, fax, street, city, region, postal_code, country}} IN orders.details WHERE order_details.order_id = orders.order_id
DELETE_ENTITY order_details

-- ============================================
-- Step 8: customers stays as Root 2 — promote PK to _id
-- ============================================
RENAME_PROPERTY customer_id TO _id IN customers
CAST_CONSTRAINT customers._id TO DOCUMENT_ID

-- ============================================
-- Step 9: orders PK -> _id; orders.customer_id stays as cross-collection reference
-- ============================================
RENAME_PROPERTY order_id TO _id IN orders
CAST_CONSTRAINT orders._id TO DOCUMENT_ID
DELETE_FOREIGN_KEY orders.customer_id
ADD_CONSTRAINT orders.customer_id AS REFERENCE LOGICAL TO customers(_id) WITH CARDINALITY ONE_TO_MANY

-- ============================================
-- Final Result (2 collections, max L3):
-- Root 1: orders { _id, order_date, required_date, shipped_date, freight, ship_name, customer_id (string ref),
--   ship_destination{ship_address, ...}, employee{..., address{...}}, shipper{...},
--   details[]{ unit_price, quantity, discount, product{name, ..., category{...}, supplier{... flat address ...}} } }
-- Root 2: customers { _id, company_name, contact_name, contact_title, phone, fax, address{...} }
-- ============================================
