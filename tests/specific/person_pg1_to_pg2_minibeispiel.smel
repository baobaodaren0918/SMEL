-- SMEL Mini-Example: PostgreSQL V1 -> PostgreSQL V2 (Specific Operations Version)
-- Same-model Schema Evolution: Relational -> Relational
-- Direction: person_postgresql.sql (V1) -> Evolved Schema (V2)
--
-- Pipeline: Source PG V1 -> Reverse Engineering -> Meta V1
--           -> SMEL Operations (this script) -> Meta V2
--           -> Forward Engineering -> Target PG V2
--
-- Operation Semantics:
--   MERGE:            Combine two entities into one (denormalization)
--   SPLIT:            Vertical partitioning into separate entities
--   RENAME_PROPERTY: Rename a field within an entity
--   RENAME_ENTITY:    Rename an entity/table
--   ADD_PROPERTY:    Add new field to entity
--   CAST:             Change field data type

MIGRATION person_pg1_to_pg2:1.0
FROM RELATIONAL TO RELATIONAL
USING person_schema:1

-- ============================================
-- Meta V1 (after Reverse Engineering of person_postgresql.sql)
-- ============================================
-- person (person_id [PK], vorname, nachname, age)
-- address (address_id [PK], person_id [FK->person], street, city)
-- employment (employment_id [PK], person_id [FK->person], position)
-- company (company_id [PK], employment_id [FK->employment], name)
-- company_address (company_address_id [PK], company_id [FK->company], street, city)
-- person_tag (person_tag_id [PK], person_id [FK->person], tag_value)
-- person_knows (person_id [PK], knows_person_id [PK], [FK->person x2])

-- ============================================
-- Target Meta V2 (will be Forward Engineered to PostgreSQL V2)
-- ============================================
-- person (person_id [PK], first_name, last_name)
-- person_detail (detail_id [PK], person_id [FK->person], age, email, phone)
-- address (address_id [PK], person_id [FK->person], street, city)       <- unchanged
-- employment (employment_id [PK], person_id [FK->person], role, start_date)
-- company (company_id [PK], employment_id [FK->employment], company_name, street, city)
-- tag (tag_id [PK], person_id [FK->person], label)
-- person_knows (person_id [PK], knows_person_id [PK], [FK->person x2]) <- unchanged

-- ============================================
-- Phase 1: Denormalize — merge company_address into company
-- Reason: 3-level JOIN depth is too deep, merge for query performance
-- ============================================
-- Before: company(company_id, employment_id, name)
--         company_address(company_address_id, company_id, street, city)
-- After:  company(company_id, employment_id, name, street, city)
DELETE_PRIMARY_KEY company_address_id FROM company_address
DELETE_CONSTRAINT company_address.company_id
DELETE_PROPERTY company_address.company_address_id
DELETE_PROPERTY company_address.company_id
MERGE company, company_address INTO company

-- ============================================
-- Phase 2: Add new fields to existing entities
-- ============================================
ADD_PROPERTY email TO person WITH TYPE String
ADD_PROPERTY phone TO person WITH TYPE String
ADD_PROPERTY start_date TO employment WITH TYPE String

-- ============================================
-- Phase 3: Split person into person + person_detail
-- Core identity stays in person, details move to person_detail
-- ============================================
-- Before: person(person_id, vorname, nachname, age, email, phone)
-- After:  person(person_id, vorname, nachname)
--         person_detail(person_id, age, email, phone)
SPLIT person INTO person:person_id, vorname, nachname; person_detail:person_id, age, email, phone
ADD_PRIMARY_KEY person_id TO person
ADD_PRIMARY_KEY person_detail.detail_id AS String
ADD_CONSTRAINT person_detail.person_id REFERENCES person(person_id) WITH CARDINALITY ONE_TO_ONE

-- ============================================
-- Phase 4: Internationalize — rename German field names
-- ============================================
RENAME_PROPERTY vorname TO first_name IN person
RENAME_PROPERTY nachname TO last_name IN person

-- ============================================
-- Phase 5: Business field renames
-- ============================================
RENAME_PROPERTY position TO role IN employment
RENAME_PROPERTY name TO company_name IN company

-- ============================================
-- Phase 6: Restructure person_tag -> tag
-- ============================================
RENAME_ENTITY person_tag TO tag
RENAME_PROPERTY person_tag_id TO tag_id IN tag
RENAME_PROPERTY tag_value TO label IN tag

-- ============================================
-- Phase 7: Type change
-- age: Integer -> String (support range values like "25-30")
-- ============================================
CAST_PROPERTY person_detail.age TO String

-- ============================================
-- Final Meta V2 (7 entities):
-- person:        { person_id [PK], first_name, last_name }
-- person_detail: { detail_id [PK], person_id [FK], age(String), email, phone }
-- address:       { address_id [PK], person_id [FK], street, city }
-- employment:    { employment_id [PK], person_id [FK], role, start_date }
-- company:       { company_id [PK], employment_id [FK], company_name, street, city }
-- tag:           { tag_id [PK], person_id [FK], label }
-- person_knows:  { person_id [PK], knows_person_id [PK] }
-- ============================================

-- ============================================
-- Operation Summary (19 steps):
--   DELETE_PRIMARY_KEY: 1    ADD_PRIMARY_KEY: 2
--   DELETE_CONSTRAINT:   1    ADD_CONSTRAINT:   1
--   DELETE_PROPERTY:   2    ADD_PROPERTY:    3
--   MERGE:              1    SPLIT:           1
--   RENAME_PROPERTY:   5    RENAME_ENTITY:   1
--   CAST:               1
-- ============================================
