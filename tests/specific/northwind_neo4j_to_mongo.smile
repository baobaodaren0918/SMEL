-- SMILE Northwind: Neo4j -> MongoDB (Specific Operations Version)
-- 7 Graph Nodes + 7 Relationships -> 2 Document Collections (orders + customers, max L3)
--
-- Operation Semantics:
--   TRANSFORM:        Convert relationship to entity (or vice versa)
--   RENAME_ENTITY:    Rename an entity
--   UNFLATTEN:        Combine flat fields into nested object
--   NEST:             Embed separate entity into parent as nested object

MIGRATION northwind_neo4j_to_mongo:1.0
FROM GRAPH TO DOCUMENT
USING adapted_northwind_schema VERSION 1

-- Declare the two surviving document roots explicitly.
-- CAST_ENTITY locks entity_kind so the auto-normalize step doesn't override.
-- Aligned with northwind_pg_to_mongo / northwind_cass_to_mongo for byte-stable output.
CAST_ENTITY orders TO DOCUMENT
CAST_ENTITY customers TO DOCUMENT

-- ============================================
-- Source: 7 nodes + 7 relationships — see northwind_neo4j.cypher
-- Target: 2 collections (orders + customers, max L3)
--   Root 1: orders { _id, ..., customer_id (REF), employee{address{}}, shipper{}, ship_destination{},
--                    details[]{ product{ category{}, supplier{flat addr} } } }
--   Root 2: customers { _id, company_name, address{} }
-- ============================================

-- ============================================
-- Step 1: TRANSFORM CONTAINS edge -> order_details entity
-- ============================================
TRANSFORM CONTAINS INTO ENTITY
RENAME_ENTITY CONTAINS TO order_details
ADD_PROPERTY order_id TO order_details WITH TYPE String
ADD_PROPERTY product_id TO order_details WITH TYPE String

-- ============================================
-- Step 2: Drop other edges, materialize FK columns
-- ============================================
DELETE_ENTITY REPORTS_TO
ADD_PROPERTY reports_to TO employees WITH TYPE String
DELETE_ENTITY SUPPLIES
ADD_PROPERTY supplier_id TO products WITH TYPE String
DELETE_ENTITY PART_OF
ADD_PROPERTY category_id TO products WITH TYPE String
DELETE_ENTITY PURCHASED
ADD_PROPERTY customer_id TO orders WITH TYPE String
-- Tighten the just-created column post-hoc: the cross-collection ref must
-- always be present (every order belongs to a customer), but NOT NULL is a
-- separate constraint from property creation.
ADD_CONSTRAINT orders.customer_id AS EXISTENCE
DELETE_ENTITY SOLD
ADD_PROPERTY employee_id TO orders WITH TYPE String
DELETE_ENTITY SHIPPED_VIA
ADD_PROPERTY shipper_id TO orders WITH TYPE String

-- ============================================
-- Step 3: UNFLATTEN address sub-objects only where the target nests them
--   - customers (Root 2: nested address)
--   - employees (will be embedded in orders.employee, address at L2)
--   - orders ship_* fields -> ship_destination L1 sub-object
-- NOT suppliers (target keeps supplier address flat at L3)
-- ============================================
UNFLATTEN customers:street, city, region, postal_code, country AS address
UNFLATTEN employees:street, city, region, postal_code, country AS address
UNFLATTEN orders:ship_address, ship_city, ship_region, ship_postal_code, ship_country AS ship_destination

-- ============================================
-- Step 4: NEST categories into products (L3 leaf)
-- ============================================
NEST categories:category_name, description IN products.category WHERE products.category_id = categories.category_id
DELETE_ENTITY categories

-- ============================================
-- Step 5: NEST suppliers into products (L3 leaf, supplier keeps flat address)
-- ============================================
NEST suppliers:company_name, contact_name, contact_title, phone, fax, street, city, region, postal_code, country IN products.supplier WHERE products.supplier_id = suppliers.supplier_id
DELETE_ENTITY suppliers

-- ============================================
-- Step 6: NEST products into order_details (L2)
-- ============================================
NEST products:product_name, unit_price, units_in_stock, discontinued, quantity_per_unit, category{category_name, description}, supplier{company_name, contact_name, contact_title, phone, fax, street, city, region, postal_code, country} IN order_details.product WHERE order_details.product_id = products.product_id
DELETE_ENTITY products

-- ============================================
-- Step 7: NEST shippers into orders (L1)
-- ============================================
NEST shippers:company_name, phone IN orders.shipper WHERE orders.shipper_id = shippers.shipper_id
DELETE_ENTITY shippers

-- ============================================
-- Step 8: NEST employees into orders (L1, with nested address at L2)
-- ============================================
NEST employees:last_name, first_name, title, birth_date, hire_date, phone, notes, reports_to, address{street, city, region, postal_code, country} IN orders.employee WHERE orders.employee_id = employees.employee_id
-- Self-reference: reports_to points at another employee in the same nested
-- collection. Re-declare the logical self-ref so the Meta V2 matches the
-- Mongo source's `_smile_self_ref` marker.
ADD_CONSTRAINT orders.employee.reports_to AS REFERENCE LOGICAL TO orders.employee(employee_id) WITH CARDINALITY ZERO_TO_ONE
DELETE_ENTITY employees

-- ============================================
-- Step 9: NEST order_details into orders.details[] (L1 array)
-- (customers stays as Root 2 — not NESTed; orders.customer_id holds the reference)
-- ============================================
NEST order_details:unit_price, quantity, discount, product{product_name, unit_price, units_in_stock, discontinued, quantity_per_unit, category{category_name, description}, supplier{company_name, contact_name, contact_title, phone, fax, street, city, region, postal_code, country}} IN orders.details WHERE order_details.order_id = orders.order_id
DELETE_ENTITY order_details

-- ============================================
-- Step 10: Promote PKs to MongoDB _id
-- ============================================
RENAME_PROPERTY order_id TO _id IN orders
CAST_CONSTRAINT orders._id TO DOCUMENT_ID
RENAME_PROPERTY customer_id TO _id IN customers
CAST_CONSTRAINT customers._id TO DOCUMENT_ID

-- Logical cross-collection reference orders.customer_id -> customers._id
ADD_CONSTRAINT orders.customer_id AS REFERENCE LOGICAL TO customers(_id) WITH CARDINALITY ONE_TO_MANY

-- ============================================
-- Final Result: 2 collections, see northwind_mongodb.json
-- ============================================
