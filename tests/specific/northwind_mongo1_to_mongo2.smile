-- SMILE Northwind: MongoDB V1 -> MongoDB V2 (Specific Operations Version)
-- Same-model Schema Evolution: Document -> Document
-- V1 / V2 are both 2-collection layouts (orders + customers, max depth 3).
--
-- V2 Business Scenario: E-commerce platform modernization
--
-- Structural changes (within both root collections):
--   FLATTEN:       Flatten category sub-object into product (denormalize, L3 -> L2)
--   UNFLATTEN:     Group customers contact fields into a contacts sub-object
--   ADD_EMBEDDED:  Add territories[] to employee with nested region (sales territory tracking)

EVOLUTION northwind_mongo1_to_mongo2:1.0
FROM DOCUMENT TO DOCUMENT
USING adapted_northwind_schema VERSION 1 TO 2

-- ============================================
-- Meta V1 (after Reverse Engineering of northwind_mongodb.json — 2 roots)
-- ============================================
-- Root 1: orders { _id [PK], order_date, required_date, shipped_date, freight, ship_name, customer_id (REF) }
--   embedded: ship_destination { ship_address, ship_city, ship_region, ship_postal_code, ship_country }
--   embedded: employee { last_name, first_name, title, birth_date, hire_date, phone, notes, reports_to }
--     embedded: address { street, city, region, postal_code, country }                              [L2]
--   embedded: shipper { company_name, phone }
--   embedded: details[] (ONE_TO_MANY)
--     embedded: product { product_name, unit_price, units_in_stock, discontinued, quantity_per_unit }
--       embedded: category { category_name, description }                                            [L3]
--       embedded: supplier { company_name, contact_name, contact_title, phone, fax,
--                            street, city, region, postal_code, country (flat address) }            [L3]
-- Root 2: customers { _id [PK], company_name, contact_name, contact_title, phone, fax }
--   embedded: address { street, city, region, postal_code, country }                                 [L1]

-- ============================================
-- Phase 1: FLATTEN category into product (structural -- reduce nesting)
-- L3 -> L2: category sub-object disappears, its fields become product fields
-- ============================================
FLATTEN orders.details.product.category
RENAME_PROPERTY category_category_name TO category_name IN product
RENAME_PROPERTY category_description TO description IN product
-- Result: product { ..., category_name, description, supplier { ... } }

-- ============================================
-- Phase 2: UNFLATTEN customer contact fields into contacts sub-object
-- Operates on Root 2 (customers collection) directly — contact fields are at L0 there.
-- ============================================
-- Before: customers { _id, company_name, contact_name, contact_title, phone, fax, address {...} }
-- After:  customers { _id, company_name, address {...}, contacts { contact_name, contact_title, phone, fax } }
UNFLATTEN customers:contact_name, contact_title, phone, fax AS contacts

-- ============================================
-- Phase 3: ADD territories[] to employee (new embedded array)
-- ============================================
-- After: employee { ..., territories[] { territory_id, territory_description, region { ... } } }
ADD_EMBEDDED territories TO employee WITH CARDINALITY ONE_TO_MANY
ADD_PROPERTY territory_id TO territories WITH TYPE String
ADD_PROPERTY territory_description TO territories WITH TYPE String

-- ============================================
-- Phase 4: ADD sales_region inside territories (nested embedded — keeps max depth = 3)
-- (Named sales_region to disambiguate from the address.region field that
--  already exists in customers/employees addresses — same word, unrelated.)
-- ============================================
-- After: territories[] { territory_id, territory_description, sales_region { region_id, region_description } }
ADD_EMBEDDED sales_region TO territories
ADD_PROPERTY region_id TO sales_region WITH TYPE String
ADD_PROPERTY region_description TO sales_region WITH TYPE String

-- ============================================
-- Phase 5: employee — simplify + ADD email
-- ============================================
DELETE_PROPERTY employee.birth_date
DELETE_PROPERTY employee.notes
ADD_PROPERTY email TO employee WITH TYPE String

-- ============================================
-- Phase 6: product + orders — RENAME + ADD
-- ============================================
RENAME_PROPERTY product_name TO name IN product
RENAME_PROPERTY freight TO shipping_cost IN orders
ADD_PROPERTY status TO orders WITH TYPE String

-- ============================================
-- Final Meta V2 (max L3 nesting, 2 roots):
-- Root 1: orders { _id, order_date, required_date, shipped_date, shipping_cost, ship_name,
--                  status, customer_id (REF) }
--   ship_destination { ship_address, ship_city, ship_region, ship_postal_code, ship_country }       [L1]
--   employee { last_name, first_name, title, hire_date, email, phone, reports_to,                   [L1]
--              address { street, city, region, postal_code, country },                              [L2]
--              territories[] { territory_id, territory_description,                                 [L2]
--                              sales_region { region_id, region_description } } }                    [L3]
--   shipper { company_name, phone }                                                                  [L1]
--   details[] { unit_price, quantity, discount,                                                      [L1]
--     product { name, unit_price, units_in_stock, discontinued, quantity_per_unit,                  [L2]
--               category_name, description,                                                          (flattened from category)
--               supplier { company_name, contact_name, contact_title, phone, fax,                   [L3]
--                          street, city, region, postal_code, country } } }
-- Root 2: customers { _id, company_name }
--   address { street, city, region, postal_code, country }                                           [L1]
--   contacts { contact_name, contact_title, phone, fax }                                             [L1]
-- ============================================
