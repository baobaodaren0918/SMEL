-- SMILE Northwind: PostgreSQL V1 -> PostgreSQL V2 (Specific Operations Version)
-- Same-model Schema Evolution: Relational -> Relational
-- V2 Business Scenario: E-commerce platform modernization
--
-- Structural changes:
--   MERGE:      Denormalize categories into products (eliminate JOIN)
--   SPLIT:      Separate customer identity from contact info (CRM)
--   ADD_ENTITY: Create region, territories, employee_territories (sales territory tracking)

EVOLUTION northwind_pg1_to_pg2:1.0
FROM RELATIONAL TO RELATIONAL
USING adapted_northwind_schema VERSION 1 TO 2

-- ============================================
-- Meta V1 (after Reverse Engineering of northwind_postgresql.sql)
-- ============================================
-- categories (category_id [PK], category_name, description)
-- suppliers (supplier_id [PK], company_name, contact_name, contact_title, phone, fax, street, city, region, postal_code, country)
-- shippers (shipper_id [PK], company_name, phone)
-- employees (employee_id [PK], last_name, first_name, title, birth_date, hire_date, phone, notes, street, city, region, postal_code, country, reports_to [FK->employees])
-- customers (customer_id [PK], company_name, contact_name, contact_title, phone, fax, street, city, region, postal_code, country)
-- products (product_id [PK], product_name, unit_price, units_in_stock, discontinued, quantity_per_unit, supplier_id [FK->suppliers], category_id [FK->categories])
-- orders (order_id [PK], order_date, required_date, shipped_date, freight, ship_name, ship_address, ship_city, ship_region, ship_postal_code, ship_country, customer_id [FK->customers], employee_id [FK->employees], shipper_id [FK->shippers])
-- order_details (order_id [PK,FK->orders], product_id [PK,FK->products], unit_price, quantity, discount)

-- ============================================
-- Phase 1: MERGE categories INTO products (structural)
-- Business: Eliminate JOIN for product catalog queries
-- ============================================
-- Before: categories(category_id, category_name, description)
--         products(..., category_id [FK->categories])
-- After:  products(..., category_name, description) -- categories removed
DELETE_FOREIGN_KEY products.category_id
DELETE_PROPERTY products.category_id
DELETE_PRIMARY_KEY category_id FROM categories
DELETE_PROPERTY categories.category_id
MERGE categories, products INTO products

-- ============================================
-- Phase 2: SPLIT customers -> customers + customer_contacts (structural)
-- Business: Separate company identity from contact person info
-- ============================================
-- Before: customers(customer_id, company_name, contact_name, contact_title, phone, fax, street, city, region, postal_code, country)
-- After:  customers(customer_id, company_name, street, city, region, postal_code, country)
--         customer_contacts(contact_id, customer_id, contact_name, contact_title, phone, fax)
SPLIT customers INTO customers:customer_id, company_name, street, city, region, postal_code, country; customer_contacts:customer_id, contact_name, contact_title, phone, fax
ADD_PRIMARY_KEY customer_id TO customers
ADD_PRIMARY_KEY customer_contacts.contact_id AS String
ADD_FOREIGN_KEY customer_contacts.customer_id REFERENCES customers(customer_id) WITH CARDINALITY ONE_TO_MANY

-- ============================================
-- Phase 3: ADD region (new entity)
-- Business: Sales territory management -- geographic regions
-- ============================================
ADD_ENTITY region WITH PROPERTIES (region_id String, region_description String)
ADD_PRIMARY_KEY region_id TO region

-- ============================================
-- Phase 4: ADD territories (new entity, FK -> region)
-- Business: Sales territories within regions
-- ============================================
ADD_ENTITY territories WITH PROPERTIES (territory_id String, territory_description String, region_id String)
ADD_PRIMARY_KEY territory_id TO territories
ADD_FOREIGN_KEY territories.region_id REFERENCES region(region_id) WITH CARDINALITY ONE_TO_MANY

-- ============================================
-- Phase 5: ADD employee_territories (M:N junction table)
-- Business: Assign employees to sales territories
-- ============================================
ADD_ENTITY employee_territories
ADD_PROPERTY employee_id TO employee_territories WITH TYPE String
ADD_PROPERTY territory_id TO employee_territories WITH TYPE String
ADD_PRIMARY_KEY (employee_id, territory_id) TO employee_territories
ADD_FOREIGN_KEY employee_territories.employee_id REFERENCES employees(employee_id) WITH CARDINALITY ONE_TO_MANY
ADD_FOREIGN_KEY employee_territories.territory_id REFERENCES territories(territory_id) WITH CARDINALITY ONE_TO_MANY

-- ============================================
-- Phase 6: employees -- simplify
-- ============================================
DELETE_PROPERTY employees.birth_date
DELETE_PROPERTY employees.notes
ADD_PROPERTY email TO employees WITH TYPE String

-- ============================================
-- Phase 7: products + orders -- RENAME + ADD
-- ============================================
RENAME_PROPERTY product_name TO name IN products
RENAME_PROPERTY freight TO shipping_cost IN orders
ADD_PROPERTY status TO orders WITH TYPE String

-- ============================================
-- Final Meta V2 (10 entities):
-- products:              { product_id [PK], name, unit_price, units_in_stock, discontinued, quantity_per_unit, supplier_id [FK], category_name, description }
-- suppliers:             { supplier_id [PK], company_name, contact_name, contact_title, phone, fax, street, city, region, postal_code, country }
-- shippers:              { shipper_id [PK], company_name, phone }
-- employees:             { employee_id [PK], last_name, first_name, title, hire_date, email, phone, street, city, region, postal_code, country, reports_to [FK] }
-- customers:             { customer_id [PK], company_name, street, city, region, postal_code, country }
-- customer_contacts:     { contact_id [PK], customer_id [FK], contact_name, contact_title, phone, fax }
-- orders:                { order_id [PK], order_date, required_date, shipped_date, shipping_cost, ship_name, ship_address, ship_city, ship_region, ship_postal_code, ship_country, customer_id [FK], employee_id [FK], shipper_id [FK], status }
-- order_details:         { order_id [PK,FK], product_id [PK,FK], unit_price, quantity, discount }
-- region:                { region_id [PK], region_description }
-- territories:           { territory_id [PK], territory_description, region_id [FK->region] }
-- employee_territories:  { employee_id [PK,FK], territory_id [PK,FK] }
-- ============================================

-- ============================================
-- Operation Summary (26 steps, 10 operation types):
--   MERGE: 1              SPLIT: 1
--   ADD_ENTITY: 3         ADD_PROPERTY: 4
--   ADD_PRIMARY_KEY: 5    ADD_FOREIGN_KEY: 4
--   DELETE_FOREIGN_KEY: 1  DELETE_PRIMARY_KEY: 1
--   DELETE_PROPERTY: 4   RENAME_PROPERTY: 2
-- ============================================
