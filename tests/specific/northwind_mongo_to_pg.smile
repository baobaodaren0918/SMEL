-- SMILE Northwind: MongoDB -> PostgreSQL (Specific Operations Version)
-- 2 Document Collections (orders + customers) -> 8 Normalized Tables (3NF)
-- Direction: Partial Denormalization (2 roots + ObjectId ref) -> Fully Normalized (3NF)
--
-- Operation Semantics:
--   UNNEST:  Extract nested object to separate table (normalization)
--   FLATTEN: Flatten nested object fields into same table (reduce depth by 1)

MIGRATION northwind_mongo_to_pg:1.0
FROM DOCUMENT TO RELATIONAL
USING adapted_northwind_schema VERSION 1

-- ============================================
-- Source: MongoDB 2 collections (max L3 nesting)
-- ============================================
-- Root 1: orders { _id, ..., customer_id (string ref to customers._id),
--   ship_destination{ship_address, ...}, employee{..., address{...}}, shipper{...},
--   details[]{ unit_price, quantity, discount,
--              product{name, ..., category{...}, supplier{... flat address ...}} } }
-- Root 2: customers { _id, company_name, contact_name, contact_title, phone, fax, address{...} }

-- ============================================
-- Target: PostgreSQL 3NF Tables (8 tables)
-- ============================================
-- categories, suppliers, shippers, employees, customers, products, orders, order_details
-- All with appropriate PKs, FKs and self-reference (employees.reports_to)

-- ============================================
-- Step 1: Rename PKs from MongoDB convention to PG convention
-- ============================================
RENAME_PROPERTY _id TO order_id IN orders
CAST_CONSTRAINT orders.order_id TO PRIMARY KEY
RENAME_PROPERTY _id TO customer_id IN customers
CAST_CONSTRAINT customers.customer_id TO PRIMARY KEY

-- ============================================
-- Step 2: FLATTEN customers.address into customers (PG has flat columns)
-- ============================================
FLATTEN customers.address
RENAME_PROPERTY address_street TO street IN customers
RENAME_PROPERTY address_city TO city IN customers
RENAME_PROPERTY address_region TO region IN customers
RENAME_PROPERTY address_postal_code TO postal_code IN customers
RENAME_PROPERTY address_country TO country IN customers
-- Result: customers { customer_id [PK], company_name, contact_name, contact_title, phone, fax, street, city, region, postal_code, country }

-- ============================================
-- Step 3: UNNEST details[] -> order_details (array extraction)
-- ============================================
UNNEST orders.details:unit_price, quantity, discount, product{product_name, unit_price, units_in_stock, discontinued, quantity_per_unit, category{category_name, description}, supplier{company_name, contact_name, contact_title, phone, fax, street, city, region, postal_code, country}} AS order_details WITH orders.order_id TO order_details.order_id

-- ============================================
-- Step 4: UNNEST employee -> employees + FLATTEN employees.address + self-ref
-- ============================================
UNNEST orders.employee:last_name, first_name, title, birth_date, hire_date, phone, notes, reports_to, address{street, city, region, postal_code, country} AS employees WITH orders.order_id TO employees.order_id
ADD_PRIMARY_KEY employees.employee_id AS String
DELETE_PROPERTY employees.order_id
ADD_PROPERTY employee_id TO orders WITH TYPE String
ADD_FOREIGN_KEY orders.employee_id REFERENCES employees(employee_id) WITH CARDINALITY ONE_TO_MANY
ADD_FOREIGN_KEY employees.reports_to REFERENCES employees(employee_id) WITH CARDINALITY ZERO_TO_MANY
FLATTEN employees.address
RENAME_PROPERTY address_street TO street IN employees
RENAME_PROPERTY address_city TO city IN employees
RENAME_PROPERTY address_region TO region IN employees
RENAME_PROPERTY address_postal_code TO postal_code IN employees
RENAME_PROPERTY address_country TO country IN employees

-- ============================================
-- Step 5: UNNEST shipper -> shippers
-- ============================================
UNNEST orders.shipper:company_name, phone AS shippers WITH orders.order_id TO shippers.order_id
ADD_PRIMARY_KEY shippers.shipper_id AS String
DELETE_PROPERTY shippers.order_id
ADD_PROPERTY shipper_id TO orders WITH TYPE String
ADD_FOREIGN_KEY orders.shipper_id REFERENCES shippers(shipper_id) WITH CARDINALITY ONE_TO_MANY

-- ============================================
-- Step 6: UNNEST product -> products (from order_details, L2)
-- Note: supplier in source has FLAT address fields (no nested address sub-object)
-- ============================================
UNNEST order_details.product:product_name, unit_price, units_in_stock, discontinued, quantity_per_unit, category{category_name, description}, supplier{company_name, contact_name, contact_title, phone, fax, street, city, region, postal_code, country} AS products WITH order_details.order_id TO products.order_id
ADD_PRIMARY_KEY products.product_id AS String
DELETE_PROPERTY products.order_id
ADD_PROPERTY product_id TO order_details WITH TYPE String
ADD_FOREIGN_KEY order_details.product_id REFERENCES products(product_id) WITH CARDINALITY ONE_TO_MANY

-- ============================================
-- Step 7: UNNEST supplier -> suppliers (no FLATTEN — supplier already had flat address)
-- ============================================
UNNEST products.supplier:company_name, contact_name, contact_title, phone, fax, street, city, region, postal_code, country AS suppliers WITH products.product_id TO suppliers.product_id
ADD_PRIMARY_KEY suppliers.supplier_id AS String
DELETE_PROPERTY suppliers.product_id
ADD_PROPERTY supplier_id TO products WITH TYPE String
ADD_FOREIGN_KEY products.supplier_id REFERENCES suppliers(supplier_id) WITH CARDINALITY ONE_TO_MANY

-- ============================================
-- Step 8: UNNEST category -> categories (from products, L3 leaf)
-- ============================================
UNNEST products.category:category_name, description AS categories WITH products.product_id TO categories.product_id
ADD_PRIMARY_KEY categories.category_id AS String
DELETE_PROPERTY categories.product_id
ADD_PROPERTY category_id TO products WITH TYPE String
ADD_FOREIGN_KEY products.category_id REFERENCES categories(category_id) WITH CARDINALITY ONE_TO_MANY

-- ============================================
-- Step 9: FLATTEN orders.ship_destination (PG has flat ship_* columns)
-- ============================================
FLATTEN orders.ship_destination
RENAME_PROPERTY ship_destination_ship_address TO ship_address IN orders
RENAME_PROPERTY ship_destination_ship_city TO ship_city IN orders
RENAME_PROPERTY ship_destination_ship_region TO ship_region IN orders
RENAME_PROPERTY ship_destination_ship_postal_code TO ship_postal_code IN orders
RENAME_PROPERTY ship_destination_ship_country TO ship_country IN orders

-- ============================================
-- Step 10: Wire up customer FK + composite PK on order_details
-- orders.customer_id was already a string in the source; just promote to FK constraint.
-- ============================================
ADD_FOREIGN_KEY orders.customer_id REFERENCES customers(customer_id) WITH CARDINALITY ONE_TO_MANY
ADD_FOREIGN_KEY order_details.order_id REFERENCES orders(order_id) WITH CARDINALITY ONE_TO_MANY
ADD_PRIMARY_KEY (order_id, product_id) TO order_details

-- ============================================
-- Final Result (8 tables): see source target file northwind_postgresql.sql
-- ============================================
