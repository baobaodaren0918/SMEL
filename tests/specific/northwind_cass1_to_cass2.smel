-- SMEL Northwind: Cassandra V1 -> Cassandra V2 (Specific Operations Version)
-- Same-model Schema Evolution: Columnar -> Columnar
-- V2 Business Scenario: E-commerce platform modernization
--
-- Structural changes:
--   MERGE:               Denormalize categories into products table
--   SPLIT:               Separate customer identity from contact info
--   Repartition orders:  Change partition key from customer_id to order_date
--   ADD_ENTITY:          Create region, territories, employee_territories (with composite partition key)

MIGRATION northwind_cass1_to_cass2:1.0
FROM COLUMNAR TO COLUMNAR
USING northwind_schema:1

-- ============================================
-- Meta V1 (after Reverse Engineering of northwind_cassandra.cql)
-- ============================================
-- categories (category_id [PARTITION], category_name, description)
-- suppliers (supplier_id [PARTITION], company_name, contact_name, contact_title, phone, fax, street, city, region, postal_code, country)
-- shippers (shipper_id [PARTITION], company_name, phone)
-- employees (employee_id [PARTITION], last_name, first_name, title, birth_date, hire_date, phone, notes, street, city, region, postal_code, country, reports_to)
-- customers (customer_id [PARTITION], company_name, contact_name, contact_title, phone, fax, street, city, region, postal_code, country)
-- products (category_id [PARTITION], supplier_id [PARTITION], product_id [CLUSTERING], product_name, unit_price, units_in_stock, discontinued, quantity_per_unit)
-- orders (customer_id [PARTITION], order_date [CLUSTERING], order_id [CLUSTERING], required_date, shipped_date, freight, ship_name, ship_address, ship_city, ship_region, ship_postal_code, ship_country, employee_id, shipper_id)
-- order_details (order_id [PARTITION], product_id [PARTITION], unit_price, quantity, discount)

-- ============================================
-- Phase 1: MERGE categories INTO products (structural + repartition)
-- Cassandra: categories partition key consumed, products repartitioned
-- ============================================
-- Before: products PK((category_id, supplier_id), product_id)
-- After:  products PK((product_id)) with category_name, description added
DELETE_PARTITION_KEY (category_id, supplier_id) FROM products
DELETE_CLUSTERING_KEY product_id FROM products
DELETE_PROPERTY products.category_id
DELETE_PARTITION_KEY category_id FROM categories
DELETE_PROPERTY categories.category_id
MERGE categories, products INTO products
ADD_PARTITION_KEY product_id TO products

-- ============================================
-- Phase 2: SPLIT customers -> customers + customer_contacts (structural)
-- ============================================
-- Before: customers PK((customer_id), ...)
-- After:  customers PK((customer_id))
--         customer_contacts PK((customer_id), contact_id)
SPLIT customers INTO customers:customer_id, company_name, street, city, region, postal_code, country; customer_contacts:customer_id, contact_name, contact_title, phone, fax
ADD_PARTITION_KEY customer_id TO customers
ADD_PARTITION_KEY customer_id TO customer_contacts
ADD_CLUSTERING_KEY contact_id TO customer_contacts

-- ============================================
-- Phase 3: Repartition orders (query optimization)
-- Change from customer-based to date-based partitioning
-- ============================================
-- Before: orders PK((customer_id), order_date, order_id)
-- After:  orders PK((order_date), customer_id, order_id)
DELETE_PARTITION_KEY customer_id FROM orders
DELETE_CLUSTERING_KEY order_date FROM orders
DELETE_CLUSTERING_KEY order_id FROM orders
ADD_PARTITION_KEY order_date TO orders
ADD_CLUSTERING_KEY customer_id TO orders
ADD_CLUSTERING_KEY order_id TO orders

-- ============================================
-- Phase 4: ADD region (new entity)
-- Business: Sales territory management -- geographic regions
-- ============================================
ADD_ENTITY region WITH PROPERTIES (region_id String, region_description String)
ADD_PARTITION_KEY region_id TO region

-- ============================================
-- Phase 5: ADD territories (new entity)
-- Business: Sales territories within regions
-- ============================================
ADD_ENTITY territories WITH PROPERTIES (territory_id String, territory_description String, region_id String)
ADD_PARTITION_KEY territory_id TO territories

-- ============================================
-- Phase 6: ADD employee_territories (composite partition key)
-- Business: Assign employees to sales territories
-- Cassandra: composite partition key (employee_id, region_id) + clustering key territory_id
-- ============================================
ADD_ENTITY employee_territories
ADD_PROPERTY employee_id TO employee_territories WITH TYPE String
ADD_PROPERTY region_id TO employee_territories WITH TYPE String
ADD_PROPERTY territory_id TO employee_territories WITH TYPE String
ADD_PARTITION_KEY (employee_id, region_id) TO employee_territories
ADD_CLUSTERING_KEY territory_id TO employee_territories

-- ============================================
-- Phase 7: employees -- simplify
-- ============================================
DELETE_PROPERTY employees.birth_date
DELETE_PROPERTY employees.notes
ADD_PROPERTY email TO employees WITH TYPE String

-- ============================================
-- Phase 8: products + orders -- RENAME + ADD
-- ============================================
RENAME_PROPERTY product_name TO name IN products
RENAME_PROPERTY freight TO shipping_cost IN orders
ADD_PROPERTY status TO orders WITH TYPE String

-- ============================================
-- Final Meta V2 (10 entities):
-- products:              { product_id [PARTITION], name, unit_price, units_in_stock, discontinued, quantity_per_unit, supplier_id, category_name, description }
-- suppliers:             { supplier_id [PARTITION], company_name, contact_name, contact_title, phone, fax, street, city, region, postal_code, country }
-- shippers:              { shipper_id [PARTITION], company_name, phone }
-- employees:             { employee_id [PARTITION], last_name, first_name, title, hire_date, email, phone, street, city, region, postal_code, country, reports_to }
-- customers:             { customer_id [PARTITION], company_name, street, city, region, postal_code, country }
-- customer_contacts:     { customer_id [PARTITION], contact_id [CLUSTERING], contact_name, contact_title, phone, fax }
-- orders:                { order_date [PARTITION], customer_id [CLUSTERING], order_id [CLUSTERING], required_date, shipped_date, shipping_cost, ship_name, ship_address, ship_city, ship_region, ship_postal_code, ship_country, employee_id, shipper_id, status }
-- order_details:         { order_id [PARTITION], product_id [PARTITION], unit_price, quantity, discount }
-- region:                { region_id [PARTITION], region_description }
-- territories:           { territory_id [PARTITION], territory_description, region_id }
-- employee_territories:  { employee_id [PARTITION], region_id [PARTITION], territory_id [CLUSTERING] }
-- ============================================

-- ============================================
-- Operation Summary (33 steps, 10 operation types):
--   MERGE: 1              SPLIT: 1
--   ADD_ENTITY: 3         ADD_PROPERTY: 5
--   ADD_PARTITION_KEY: 7  ADD_CLUSTERING_KEY: 4
--   DELETE_PARTITION_KEY: 3  DELETE_CLUSTERING_KEY: 3
--   DELETE_PROPERTY: 4   RENAME_PROPERTY: 2
-- ============================================
