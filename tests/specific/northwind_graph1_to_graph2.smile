-- SMILE Northwind: Neo4j V1 -> Neo4j V2 (Specific Operations Version)
-- Same-model Schema Evolution: Graph -> Graph
-- V2 Business Scenario: E-commerce platform modernization
--
-- Structural changes:
--   MERGE:         Combine categories into products node (denormalize graph)
--   SPLIT:         Separate customers into customers + contact nodes
--   ADD_ENTITY:    Create sales_region, territories nodes (sales territory tracking)
--   ADD_ENTITY:    Create HAS_CONTACT, BELONGS_TO, ASSIGNED_TO edges
--   ADD_LABEL:     Multi-label node (suppliers + Vendor)

EVOLUTION northwind_graph1_to_graph2:1.0
FROM GRAPH TO GRAPH
USING adapted_northwind_schema VERSION 1 TO 2

-- ============================================
-- Meta V1 (after Reverse Engineering of northwind_neo4j.cypher)
-- ============================================
-- 7 Nodes:
--   categories { category_id, category_name, description }
--   suppliers { supplier_id, company_name, contact_name, contact_title, phone, fax, street, city, region, postal_code, country }
--   shippers { shipper_id, company_name, phone }
--   employees { employee_id, last_name, first_name, title, birth_date, hire_date, phone, notes, street, city, region, postal_code, country }
--   customers { customer_id, company_name, contact_name, contact_title, phone, fax, street, city, region, postal_code, country }
--   products { product_id, product_name, unit_price, units_in_stock, discontinued, quantity_per_unit }
--   orders { order_id, order_date, required_date, shipped_date, freight, ship_name, ship_address, ship_city, ship_region, ship_postal_code, ship_country }
-- 7 Relationships:
--   SUPPLIES (suppliers -> products), PART_OF (products -> categories)
--   PURCHASED (customers -> orders), SOLD (employees -> orders)
--   SHIPPED_VIA (orders -> shippers), REPORTS_TO (employees -> employees)
--   CONTAINS (orders -> products) [props: unit_price, quantity, discount]

-- ============================================
-- Phase 1: MERGE categories INTO products (structural)
-- Graph equivalent of denormalization: eliminate PART_OF relationship
-- ============================================
-- Before: products -[PART_OF]-> categories { category_id, category_name, description }
-- After:  products { ..., category_name, description }
DELETE_ENTITY PART_OF
DELETE_PROPERTY categories.category_id
MERGE categories, products INTO products

-- ============================================
-- Phase 2: SPLIT customers -> customers + contact (structural)
-- Graph equivalent of CRM separation: create contact node with relationship
-- ============================================
-- Before: customers { customer_id, company_name, contact_name, contact_title, phone, fax, ... }
-- After:  customers { customer_id, company_name, ... } -[HAS_CONTACT]-> contact { contact_id, ... }
SPLIT customers INTO customers:customer_id, company_name, street, city, region, postal_code, country; contact:customer_id, contact_name, contact_title, phone, fax
-- customers retained customer_id and its NODE KEY from the pre-SPLIT entity;
-- CAST_CONSTRAINT alone re-affirms the NODE KEY subtype, no intermediate
-- ADD_*_KEY needed because the identity constraint is already in place.
CAST_CONSTRAINT customers.customer_id TO NODE KEY
-- contact also inherited customer_id and its NODE KEY from SPLIT. To clear
-- that inherited identity in paradigm-correct vocabulary, first DEMOTE the
-- NODE_KEY to a plain UNIQUE constraint (CAST_CONSTRAINT TO UNIQUE_KEY just
-- flips is_primary_key=False), then DELETE_UNIQUE_KEY removes it. Finally
-- add contact_id as the entity's own identity via the standard staging
-- pattern: ADD_UNIQUE_KEY (creates kind=unique, is_primary_key=False) +
-- CAST_CONSTRAINT TO NODE KEY (elevates to is_primary_key=True, NODE_KEY).
-- This avoids DELETE_PRIMARY_KEY entirely in a pure-Neo4j context.
CAST_CONSTRAINT contact.customer_id TO UNIQUE KEY
DELETE_UNIQUE_KEY customer_id FROM contact
ADD_UNIQUE_KEY contact.contact_id AS String
CAST_CONSTRAINT contact.contact_id TO NODE KEY
-- Declare contact.customer_id as a logical 1..1 reference back to customers,
-- then DELETE_CONSTRAINT removes the Reference (caching its cardinality via
-- the trace) while leaving the customer_id column itself intact — matching
-- V2's dual representation (graph edge + back-ref column).
-- ADD_CONSTRAINT REFERENCE LOGICAL is used here (not ADD_FOREIGN_KEY)
-- because Neo4j has no FK paradigm — this is a paradigm-neutral logical ref.
ADD_CONSTRAINT contact.customer_id AS REFERENCE LOGICAL TO customers(customer_id) WITH CARDINALITY ONE_TO_ONE
DELETE_CONSTRAINT contact.customer_id
ADD_ENTITY HAS_CONTACT FROM customers TO contact

-- ============================================
-- Phase 3: ADD sales_region node (new entity)
-- Business: Geographic region for sales territory management
-- (Named sales_region to disambiguate from the address.region property
--  already present on customers/employees/suppliers — same word,
--  unrelated concept.)
-- ============================================
ADD_ENTITY sales_region WITH PROPERTIES (region_id String, region_description String)
ADD_UNIQUE_KEY region_id TO sales_region
CAST_CONSTRAINT sales_region.region_id TO NODE KEY

-- ============================================
-- Phase 4: ADD territories node (new entity, edge -> sales_region)
-- Business: Sales territories within sales_region
-- ============================================
ADD_ENTITY territories WITH PROPERTIES (territory_id String, territory_description String)
ADD_UNIQUE_KEY territory_id TO territories
CAST_CONSTRAINT territories.territory_id TO NODE KEY
ADD_ENTITY BELONGS_TO FROM territories TO sales_region WITH CARDINALITY ONE_TO_ONE

-- ============================================
-- Phase 5: ADD ASSIGNED_TO edge (employees -> territories, M:N)
-- Business: Assign employees to sales territories
-- ============================================
ADD_ENTITY ASSIGNED_TO FROM employees TO territories

-- ============================================
-- Phase 6: employees -- simplify + ADD
-- ============================================
DELETE_PROPERTY employees.birth_date
DELETE_PROPERTY employees.notes
ADD_PROPERTY email TO employees WITH TYPE String

-- ============================================
-- Phase 7: products + orders -- RENAME + ADD
-- ============================================
RENAME_PROPERTY product_name TO name IN products
RENAME_PROPERTY freight TO shipping_cost IN orders
ADD_PROPERTY status TO orders WITH TYPE String

-- ============================================
-- Phase 8: suppliers -- ADD_LABEL
-- ============================================
ADD_LABEL Vendor TO suppliers

-- ============================================
-- Final Meta V2 (9 nodes, 9 relationships):
-- products:     { product_id [NK], name, unit_price, units_in_stock, discontinued, quantity_per_unit, category_name, description }
-- suppliers:    { supplier_id [NK], company_name, contact_name, contact_title, phone, fax, street, city, region, postal_code, country } +Vendor
-- shippers:     { shipper_id [NK], company_name, phone }
-- employees:    { employee_id [NK], last_name, first_name, title, hire_date, email, phone, street, city, region, postal_code, country }
-- customers:    { customer_id [NK], company_name, street, city, region, postal_code, country }
-- contact:      { contact_id [NK], customer_id, contact_name, contact_title, phone, fax }
-- orders:       { order_id [NK], order_date, required_date, shipped_date, shipping_cost, ship_name, ship_address, ship_city, ship_region, ship_postal_code, ship_country, status }
-- sales_region: { region_id [NK], region_description }
-- territories:  { territory_id [NK], territory_description }
-- [categories MERGED into products, PART_OF deleted]
-- [customers SPLIT -> customers + contact, HAS_CONTACT added]
-- Relationships: SUPPLIES, PURCHASED, SOLD, SHIPPED_VIA, REPORTS_TO, CONTAINS,
--                HAS_CONTACT, BELONGS_TO, ASSIGNED_TO
-- ============================================

-- ============================================
-- Operation Summary (27 steps, 13 operation types):
--   MERGE: 1              SPLIT: 1
--   ADD_ENTITY: 2         ADD_PROPERTY: 2
--   ADD_UNIQUE_KEY: 3     CAST_CONSTRAINT: 5
--   ADD_ENTITY(edge): 3   DELETE_ENTITY: 1
--   DELETE_PROPERTY: 3    RENAME_PROPERTY: 2
--   DELETE_UNIQUE_KEY: 1  ADD_CONSTRAINT: 1
--   DELETE_CONSTRAINT: 1  ADD_LABEL: 1
-- ============================================
